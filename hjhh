local ActiveLoops = {}

local function StartManagedLoop(loopName, isRunning, tickFn, errorDelay)
   if ActiveLoops[loopName] then
      return
   end

   ActiveLoops[loopName] = true
   task.spawn(function()
      while isRunning() do
         local ok, waitTime = pcall(tickFn)
         if ok then
            if type(waitTime) == "number" and waitTime > 0 then
               task.wait(waitTime)
            end
         else
            task.wait(errorDelay or 1)
         end
      end

      ActiveLoops[loopName] = nil
   end)
end

local UpgradePurchaseAmount = 1
local FeedAmount = 10
local PriorityUpgradeIds = {
   "FireAnt",
   "AntQueen",
   "DoubleAnt",
   "WorkerAnt"
}
local SecondaryUpgradeIds = {
   "MegaClick",
   "PowerClick",
   "SharpClick",
   "SwiftClick",
   "BasicClick"
}
local AscensionUpgradeOrder = {
   "AscTokens",
   "AscCoins",
   "AscPerSecond",
   "AscRuneBulk",
   "RuneLuck",
   "AscDamage",
   "AscHealth"
}

local function FireClick()
   local args = {}
   ClickEvent:FireServer(unpack(args))
end

local function FireUpgradeBatch()
   local upgrades = {}

   for _, upgradeId in ipairs(PriorityUpgradeIds) do
      upgrades[#upgrades + 1] = {
         Id = upgradeId,
         Amount = UpgradePurchaseAmount,
      }
   end

   for _, upgradeId in ipairs(SecondaryUpgradeIds) do
      upgrades[#upgrades + 1] = {
         Id = upgradeId,
         Amount = UpgradePurchaseAmount,
      }
   end

   local args = {
      upgrades,
   }

   UpgradeEvent:FireServer(unpack(args))
end

local function FeedQueen(amount)
   local args = {
      "Feed",
      amount,
   }

   AntQueenFeedEvent:FireServer(unpack(args))
end

local function Ascend()
   local args = {
      "Ascend",
   }

   AscensionEvent:FireServer(unpack(args))
end

local function BuyAscensionUpgrade(upgradeId)
   local args = {
      "BuyUpgrade",
      upgradeId,
      1,
   }

   AscensionEvent:FireServer(unpack(args))
end

local function BuyAscensionUpgradeOrder()
   for _, upgradeId in ipairs(AscensionUpgradeOrder) do
      BuyAscensionUpgrade(upgradeId)
      task.wait(0.05)
   end
end

