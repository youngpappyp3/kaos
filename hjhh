local function ParseCurrencyAmount(text)
   local sanitized = tostring(text or ""):gsub(",", "")
   local amount = tonumber(sanitized:match("%-?[%d%.]+"))
   return amount or 0
end

local function FindCurrencyLabel(rowNames, countNames)
   for _, rowName in ipairs(rowNames) do
      local row = CurrencyFrame:FindFirstChild(rowName, true)
      if row then
         for _, countName in ipairs(countNames) do
            local countLabel = row:FindFirstChild(countName, true)
            if countLabel then
               return countLabel
            end
         end

         local fallbackLabel = row:FindFirstChildWhichIsA("TextLabel", true)
         if fallbackLabel then
            return fallbackLabel
         end
      end
   end
end

local GoldenCountLabel = FindCurrencyLabel({"GoldenRow"}, {"GoldenCount"})
local PotatoCountLabel = FindCurrencyLabel({"PotatoRow", "PotatoesRow", "NormalRow"}, {"PotatoCount", "Count"})

local function FindStaminaLabel()
   local preferredNames = {
      "StaminaValue",
      "StaminaLabel",
      "StaminaText",
      "CurrentStamina"
   }

   for _, name in ipairs(preferredNames) do
      local label = PotatoGameGui:FindFirstChild(name, true)
      if label and label:IsA("TextLabel") then
         return label
      end
   end

   for _, descendant in ipairs(PotatoGameGui:GetDescendants()) do
      if descendant:IsA("TextLabel") then
         local text = tostring(descendant.Text or "")
         if text:match("^%s*[%d,%.]+%s*/%s*[%d,%.]+%s*$") then
            return descendant
         end
      end
   end
end

local StaminaLabel = FindStaminaLabel()

local function GetStaminaValues()
   if not StaminaLabel or not StaminaLabel.Parent then
      StaminaLabel = FindStaminaLabel()
   end

   if not StaminaLabel then
      return nil, nil
   end

   local currentText, maxText = tostring(StaminaLabel.Text or ""):match("([%d,%.]+)%s*/%s*([%d,%.]+)")
   if not currentText or not maxText then
      return nil, nil
   end

   return ParseCurrencyAmount(currentText), ParseCurrencyAmount(maxText)
end

local function GetGoldenCountLabel()
   if not GoldenCountLabel or not GoldenCountLabel.Parent then
      GoldenCountLabel = FindCurrencyLabel({"GoldenRow"}, {"GoldenCount"})
   end

   return GoldenCountLabel
end

local function GetPotatoCountLabel()
   if not PotatoCountLabel or not PotatoCountLabel.Parent then
      PotatoCountLabel = FindCurrencyLabel({"PotatoRow", "PotatoesRow", "NormalRow"}, {"PotatoCount", "Count"})
   end

   return PotatoCountLabel
end

local ActiveLoops = {}

local function StartManagedLoop(loopName, isRunning, tickFn, errorDelay)
   if ActiveLoops[loopName] then
      return
   end

   ActiveLoops[loopName] = true
   task.spawn(function()
      while isRunning() do
         local ok, waitTime = pcall(tickFn)
         if ok then
            if type(waitTime) == "number" and waitTime > 0 then
               task.wait(waitTime)
            end
         else
            task.wait(errorDelay or 1)
         end
      end

      ActiveLoops[loopName] = nil
   end)
end

local function SellCurrentGoldenPotatoes()
   local goldenLabel = GetGoldenCountLabel()
   if goldenLabel then
      local gold = ParseCurrencyAmount(goldenLabel.Text)
      if gold > 0 then
         SellGoldenPotatoes:FireServer(gold)
      end
   end
end

local function SellCurrentPotatoes()
   local potatoLabel = GetPotatoCountLabel()
   if potatoLabel then
      local potatoes = ParseCurrencyAmount(potatoLabel.Text)
      if potatoes > 0 then
         SellPotatoes:FireServer(potatoes)
      end
   end
end

