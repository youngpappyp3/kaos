do
MacroTab:CreateSection("All-in-One Macro")
MacroStatusLabel = MacroTab:CreateLabel("Status: Idle")

local MacroRunning = false
local MacroIncludeInventory = true
local MacroIncludeRewards = true
local MacroIncludeCraft = false
local MacroTargetMode = "Best Available"

MacroTab:CreateDropdown({
    Name = "Macro Target Mode",
    Options = { "Best Available", "Boss/Rare First", "Nearest Mob", "Nearest Resource" },
    CurrentOption = { "Best Available" },
    MultipleOptions = false,
    Flag = "PetsAdventureMacroTargetMode",
    Callback = function(v)
        MacroTargetMode = GetDropdownChoice(v, MacroTargetMode)
    end,
})

MacroTab:CreateToggle({
    Name = "Include Inventory Opens",
    CurrentValue = true,
    Flag = "PetsAdventureMacroInventory",
    Callback = function(v)
        MacroIncludeInventory = v
    end,
})

MacroTab:CreateToggle({
    Name = "Include Rewards",
    CurrentValue = true,
    Flag = "PetsAdventureMacroRewards",
    Callback = function(v)
        MacroIncludeRewards = v
    end,
})

MacroTab:CreateToggle({
    Name = "Include Crafting",
    CurrentValue = false,
    Flag = "PetsAdventureMacroCrafting",
    Callback = function(v)
        MacroIncludeCraft = v
    end,
})

MacroTab:CreateToggle({
    Name = "PetsMax Macro",
    CurrentValue = false,
    Flag = "PetsAdventurePetsMaxMacro",
    Callback = function(v)
        MacroRunning = v
        if MacroRunning then
            local lastUpgrade = 0
            local lastReward = 0
            local lastInventory = 0
            local lastCraft = 0
            StartManagedLoop("PetsMaxMacro", function() return MacroRunning end, function()
                local now = os.clock()

                local target = ChooseTarget(MacroTargetMode)
                if target then
                    SetAllPetAction("Auto")
                    TargetForPets(target.target)
                    SetStatus(MacroStatusLabel, "Status", "Targeting " .. target.target.Name)
                end

                if now - lastUpgrade >= 1 then
                    lastUpgrade = now
                    local upgradeId = ChooseUpgrade("Best Value")
                    if upgradeId then
                        BuyUpgrade(upgradeId)
                    end
                    if CanRebirth() then
                        SafeInvoke("RequestRebirth")
                    end
                end

                if MacroIncludeRewards and now - lastReward >= 20 then
                    lastReward = now
                    ClaimDailyAvailable()
                    SafeInvoke("ClaimSocialBoost", "FavoriteBoost")
                    SafeInvoke("ClaimSocialBoost", "GroupBoost")
                    AutoSpinOnce()
                    RollFountainOnce()
                end

                if MacroIncludeInventory and now - lastInventory >= 10 then
                    lastInventory = now
                    OpenInventoryType("Egg", "HatchEggs", "All")
                    OpenInventoryType("MysteryBox", "OpenChest", "All")
                    UseAllPotions()
                end

                if MacroIncludeCraft and now - lastCraft >= 15 then
                    lastCraft = now
                    ClaimReadyCrafts()
                    local recipeId = ChooseCraftRecipe("First Affordable", nil)
                    if recipeId then
                        SafeInvoke("StartCraft", recipeId)
                    end
                end

                return 0.35
            end, 2)
        else
            SetStatus(MacroStatusLabel, "Status", "Idle")
        end
    end,
})
end

