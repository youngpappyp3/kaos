("AutoUpgradeBestBrawlers", function() return AutoUpgradeBestBrawlers end, function()
                -- Upgrade ALL affordable brawlers, not just one candidate
                local totalUpgraded = 0

                -- Ensure we have the PurchaseBrawlerUpgrade remote
                local upgradeRemote = PurchaseBrawlerUpgrade
                if not upgradeRemote then
                    local remotes = game:GetService("ReplicatedStorage"):FindFirstChild("Remotes")
                    if remotes then
                        upgradeRemote = remotes:FindFirstChild("PurchaseBrawlerUpgrade")
                    end
                end
                if not upgradeRemote then
                    SetBrawlerUpgradeStatus("Missing upgrade remote")
                    HubLog("BrawlerUpgrade", "PurchaseBrawlerUpgrade remote not found")
                    return BrawlerUpgradeDelay
                end

                -- Build list of unlocked, non-max brawlers from inventory snapshot
                local brawlersToTry = {}
                local snapshotOk, snapshotData = SafeInvoke(GetInventorySnapshot)
                if snapshotOk and typeof(snapshotData) == "table" then
                    local byId = snapshotData.byId or snapshotData
                    if typeof(byId) == "table" then
                        for brawlerId, state in pairs(byId) do
                            if typeof(state) == "table" and state.unlocked == true then
                                local level = tonumber(state.level) or 1
                                if level < 11 then -- MaxLevel = 11
                                    table.insert(brawlersToTry, {
                                        id = brawlerId,
                                        level = level,
                                    })
                                end
                            end
                        end
                    end
                end

                -- Sort by level ascending so we spread upgrades across brawlers
                table.sort(brawlersToTry, function(a, b)
                    return a.level < b.level
                end)

                SetBrawlerUpgradeStatus("Checking " .. #brawlersToTry .. " brawlers...")
                HubLog("BrawlerUpgrade", "Trying " .. #brawlersToTry .. " brawlers for upgrade")

                for _, brawler in ipairs(brawlersToTry) do
                    if not AutoUpgradeBestBrawlers then break end

                    local callOk, result = pcall(function()
                        return upgradeRemote:InvokeServer(brawler.id)
                    end)

                    if callOk and typeof(result) == "table" then
                        if result.ok == true then
                            totalUpgraded = totalUpgraded + 1
                            HubLog("BrawlerUpgrade", "Upgraded " .. tostring(brawler.id))
                            SetBrawlerUpgradeStatus("Upgraded " .. tostring(brawler.id))
                            InvalidateInventorySnapshot()
                            task.wait(0.15)
                        else
                            local msg = result.message or "Unknown"
                            HubLog("BrawlerUpgrade", "Skipped " .. tostring(brawler.id) .. ": " .. msg)
                            -- Don't break - try next brawler (different level = different cost)
                        end
                    elseif not callOk then
                        HubLog("BrawlerUpgrade", "Error upgrading " .. tostring(brawler.id) .. ": " .. tostring(result))
                    end
                end

                if totalUpgraded > 0 then
                    SetBrawlerUpgradeStatus("Upgraded " .. totalUpgraded .. " brawler(s)")
                else
                    SetBrawlerUpgradeStatus("No brawlers could be upgraded")
                end

                return BrawlerUpgradeDelay
            end, 2)
        else
            SetBrawlerUpgradeStatus("Idle")
        end
    end,
})

end

