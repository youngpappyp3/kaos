local function CanCraftRecipe(recipe)
    if typeof(recipe) ~= "table" or typeof(recipe.inputs) ~= "table" then
        return false
    end
    for _, input in ipairs(recipe.inputs) do
        if input.type == "currency" then
            if GetCurrency(input.id) < (tonumber(input.amount) or 0) then
                return false
            end
        elseif input.type == "item" then
            if GetInventoryItemCount(input.id) < (tonumber(input.amount) or 0) then
                return false
            end
        end
    end
    return true
end

local function ChooseCraftRecipe(mode, manualRecipe)
    if manualRecipe and manualRecipe ~= "" and CraftingConfig and CraftingConfig.GetRecipe then
        return CraftingConfig.GetRecipe(manualRecipe) and manualRecipe or nil
    end
    if not CraftingConfig or typeof(CraftingConfig.RecipeOrder) ~= "table" or not CraftingConfig.GetRecipe then
        return nil
    end
    if mode == "First Affordable" then
        for _, recipeId in ipairs(CraftingConfig.RecipeOrder) do
            local recipe = CraftingConfig.GetRecipe(recipeId)
            if CanCraftRecipe(recipe) then
                return recipeId
            end
        end
    end
    return nil
end

local function ClaimReadyCrafts()
    local claimed = 0
    if typeof(CraftingCache) ~= "table" then
        return 0
    end
    local slots = CraftingCache.slots or CraftingCache.Slots or CraftingCache
    if typeof(slots) ~= "table" then
        return 0
    end
    for slotIndex, slot in pairs(slots) do
        if typeof(slot) == "table" then
            local ready = slot.ready == true or slot.isReady == true or (tonumber(slot.endTime) and tonumber(slot.endTime) <= os.time())
            if ready then
                SafeInvoke("ClaimCraft", tonumber(slotIndex) or slotIndex)
                claimed += 1
                task.wait(0.1)
            end
        end
    end
    return claimed
end

local function MerchantSellAllOffers()
    local sold = 0
    if not MerchantConfig or typeof(MerchantConfig.Offers) ~= "table" then
        return 0
    end
    for _, offer in ipairs(MerchantConfig.Offers) do
        if offer.itemId then
            local count = GetInventoryItemCount(offer.itemId)
            if count > 0 then
                SafeFire("MerchantSell", offer.itemId, count)
                sold += count
                task.wait(0.15)
            end
        end
    end
    return sold
end

local function GetZoneOptions()
    local options = {}
    if ZoneConfig and typeof(ZoneConfig.Zones) == "table" then
        for index, zone in ipairs(ZoneConfig.Zones) do
            options[#options + 1] = zone.Name or zone.Map or tostring(index)
        end
    end
    if #options <= 0 then
        options = { "Spawn", "Grasslands", "Desert", "Arctic", "Volcano", "Crystal", "Slime" }
    end
    return options
end

local function FindZoneIdByName(name)
    if ZoneConfig and typeof(ZoneConfig.Zones) == "table" then
        for index, zone in ipairs(ZoneConfig.Zones) do
            if zone.Name == name or zone.Map == name or tostring(index) == tostring(name) then
                return index, zone
            end
        end
    end
    return name, nil
end

