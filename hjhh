    local best = nil
    for brawlerId, state in pairs(inventory.byId) do
        if typeof(brawlerId) == "string" and CanUpgradeBrawler(brawlerId, state, targetLevel) then
            local score = ScoreBrawlerUpgradeCandidate(brawlerId, state, mode, targetLevel)
            if score and (not best or score > best.score) then
