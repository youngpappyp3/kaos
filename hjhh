                if stateOk and typeof(state) == "table" and typeof(state.completedResult) == "table" then
                    pcall(function()
                        AcknowledgeBattleResult:InvokeServer({ deferBoxRewards = true })
                    end)
                end
                return 3
            end, 3)
        end
    end,
})

