local BrawlerUpgradeBatchSize = 3
local BrawlerUpgradeDelay = 2
local BrawlerUpgradeStatusLabel = UpgradeTab:CreateLabel("Brawler Upgrades: Idle")

local function SetBrawlerUpgradeStatus(text)
    SetRayfieldLabel(BrawlerUpgradeStatusLabel, "Brawler Upgrades: " .. tostring(text or "-"))
end

local function RunBrawlerUpgradeBatch()
    local upgraded = 0
    local lastName = nil
    local lastReason = nil
    local skippedThisBatch = {}
    local attempts = 0
    local maxAttempts = math.max(BrawlerUpgradeBatchSize + 3, BrawlerUpgradeBatchSize * 3)

    while upgraded < BrawlerUpgradeBatchSize and attempts < maxAttempts do
        attempts += 1
        local brawlerId, reason, candidateState = ChooseBrawlerUpgradeCandidate(
            BrawlerUpgradeMode,
            BrawlerUpgradeTargetLevel,
            BrawlerUpgradeMinRarity,
            BrawlerUpgradeIncludeRoles,
            skippedThisBatch
        )
        if not brawlerId then
            lastReason = reason
            break
        end

        HubDebug(
            "BrawlerUpgradeAttempt",
            "Trying " .. GetBrawlerUpgradeDebugText(brawlerId, candidateState)
                .. " | mode=" .. tostring(BrawlerUpgradeMode)
                .. " minRarity=" .. tostring(BrawlerUpgradeMinRarity)
                .. " includeRoles=" .. tostring(BrawlerUpgradeIncludeRoles)
                .. " targetLevel=" .. tostring(BrawlerUpgradeTargetLevel)
        )

        local ok, result = SmartPurchaseBrawlerUpgrade(brawlerId, candidateState)
        if not ok then
            lastReason = tostring(result or "upgrade failed")
            HubDebug("BrawlerUpgrade", "Failed " .. tostring(brawlerId) .. ": " .. lastReason)
            skippedThisBatch[brawlerId] = true
            task.wait(0.05)
            continue
        end

        upgraded += 1
        lastName = GetBrawlerDisplayName(brawlerId)
        HubDebug("BrawlerUpgrade", "Upgraded " .. tostring(brawlerId))
        task.wait(0.15)
    end

    if upgraded > 0 then
        SetBrawlerUpgradeStatus("Upgraded " .. tostring(upgraded) .. " | Last: " .. tostring(lastName or "-"))
        return true
    end

    SetBrawlerUpgradeStatus(tostring(lastReason or "nothing to upgrade"))
    HubDebug("BrawlerUpgrade", tostring(lastReason or "nothing to upgrade"))
    return false
end

local function DebugBrawlerUpgradeState()
    local _, inventory = GetBattleSlots()
    local remoteText = PurchaseBrawlerUpgrade and (PurchaseBrawlerUpgrade.ClassName or "exists") or "missing"
    local moduleText = BrawlerProgressionConfig and "loaded" or "missing/server-check"
    local coins = GetCoins()
    local powerPoints = GetPowerPoints()
    local unlocked = 0
    local matched = 0
    local affordable = 0
    local blockedByCost = 0
    local temporarilySkipped = 0
    local costUnknown = 0
    local maxedOrTarget = 0
    local firstBlocked = nil

    if typeof(inventory) == "table" and typeof(inventory.byId) == "table" then
        for brawlerId, state in pairs(inventory.byId) do
            if typeof(brawlerId) == "string" and typeof(state) == "table" and state.unlocked == true then
                unlocked += 1
                if IsBrawlerAllowedByUpgradeFilter(brawlerId, state, inventory, BrawlerUpgradeMinRarity, BrawlerUpgradeIncludeRoles) then
                    matched += 1
                    local costs = GetBrawlerUpgradeCost(brawlerId, state)
                    local level = math.max(1, math.floor(tonumber(state.level) or 1))
                    local maxLevel = tonumber(BrawlerProgressionConfig and BrawlerProgressionConfig.MaxLevel) or 11
                    local wantedLevel = math.clamp(math.floor(tonumber(BrawlerUpgradeTargetLevel) or maxLevel), 1, maxLevel)
                    local serverBlockReason = GetBrawlerUpgradeTemporaryBlockReason(brawlerId)
                    if serverBlockReason then
                        temporarilySkipped += 1
                        if not firstBlocked then
                            firstBlocked = GetBrawlerDisplayName(brawlerId) .. " skipped: " .. tostring(serverBlockReason)
                        end
                    elseif not costs and level < maxLevel and level < wantedLevel then
                        costUnknown += 1
                        affordable += 1
                    elseif CanUpgradeBrawler(brawlerId, state, BrawlerUpgradeTargetLevel) then
                        affordable += 1
                    elseif costs and level < maxLevel and level < wantedLevel then
                        blockedByCost += 1
                        if not firstBlocked then
                            firstBlocked = string.format(
                                "%s L%d needs %d coins/%d pp",
                                GetBrawlerDisplayName(brawlerId),
                                level,
                                costs.coins,
                                costs.powerPoints
                            )
                        end
                    else
                        maxedOrTarget += 1
                    end
                end
            end
        end
    end

    local candidateId, reason = ChooseBrawlerUpgradeCandidate(
        BrawlerUpgradeMode,
        BrawlerUpgradeTargetLevel,
        BrawlerUpgradeMinRarity,
        BrawlerUpgradeIncludeRoles
    )
    local candidateText = candidateId and GetBrawlerDisplayName(candidateId) or tostring(reason or "-")
    local summary = string.format(
        "remote=%s | module=%s | mode=%s | min=%s | roles=%s | target=%d | coins=%d | pp=%d | unlocked=%d | matched=%d | affordable=%d | costUnknown=%d | costBlocked=%d | skipped=%d | max/target=%d | candidate=%s",
        remoteText,
        moduleText,
        tostring(BrawlerUpgradeMode),
        tostring(BrawlerUpgradeMinRarity),
        tostring(BrawlerUpgradeIncludeRoles),
        tonumber(BrawlerUpgradeTargetLevel) or 11,
        coins,
        powerPoints,
        unlocked,
        matched,
        affordable,
        costUnknown,
        blockedByCost,
        temporarilySkipped,
        maxedOrTarget,
        candidateText
    )

    if firstBlocked then
        summary = summary .. " | firstBlocked=" .. firstBlocked
    end

    HubDebug("BrawlerUpgradeDebug", summary)
    SetBrawlerUpgradeStatus("Debug: " .. candidateText)
    SafeNotify({
        Title = "Brawler Upgrade Debug",
        Content = summary,
        Duration = 8,
    })
end

