        end
        return ok, result
    end
    return false, nil
end

local function GetBrawlerUpgradeCost(brawlerId, state)
    if not BrawlerProgressionConfig or not BrawlerProgressionConfig.getUpgradeCostsForLevel then
        return nil
    end

    local brawler = BrawlerLibrary and BrawlerLibrary.ById and BrawlerLibrary.ById[brawlerId] or nil
    local rarity = brawler and brawler.rarity or nil
    local ok, costs = pcall(function()
        return BrawlerProgressionConfig.getUpgradeCostsForLevel(state and state.level or 1, rarity)
    end)
    if ok and typeof(costs) == "table" then
        return {
            coins = math.max(0, math.floor(tonumber(costs.coins) or 0)),
            powerPoints = math.max(0, math.floor(tonumber(costs.powerPoints) or 0)),
        }
    end
    return nil
end

local function GetBrawlerUpgradeDebugText(brawlerId, state)
    local brawler = BrawlerLibrary and BrawlerLibrary.ById and BrawlerLibrary.ById[brawlerId] or nil
    local level = math.max(1, math.floor(tonumber(state and state.level) or 1))
    local rarity = brawler and brawler.rarity or "?"
    local costs = GetBrawlerUpgradeCost(brawlerId, state)
    local coins = GetCoins()
    local powerPoints = GetPowerPoints()
    local classKey = GetBrawlerClassKey(brawlerId) or "-"
    local selectedText = IsBrawlerInBattleSlots(brawlerId, ({ GetBattleSlots() })[2]) and "yes" or "no"
    local roleText = IsBrawlerRecommendedForCurrentMap(brawlerId) and "yes" or "no"

    if costs then
        return string.format(
            "%s (%s) id=%s rarity=%s class=%s level=%d cost=%d coins/%d pp balance=%d coins/%d pp selected=%s roleMatch=%s",
            GetBrawlerDisplayName(brawlerId),
            tostring(brawlerId),
            tostring(brawlerId),
            tostring(rarity),
            tostring(classKey),
            level,
            costs.coins,
            costs.powerPoints,
            coins,
            powerPoints,
            selectedText,
            roleText
        )
    end

    return string.format(
        "%s (%s) id=%s rarity=%s class=%s level=%d cost=max/unknown balance=%d coins/%d pp selected=%s roleMatch=%s",
        GetBrawlerDisplayName(brawlerId),
        tostring(brawlerId),
        tostring(brawlerId),
        tostring(rarity),
        tostring(classKey),
        level,
        coins,
        powerPoints,
        selectedText,
        roleText
    )
end

local function CanUpgradeBrawler(brawlerId, state, targetLevel)
    if not PurchaseBrawlerUpgrade or typeof(state) ~= "table" or state.unlocked ~= true then
        return false
    end

    local maxLevel = tonumber(BrawlerProgressionConfig and BrawlerProgressionConfig.MaxLevel) or 11
    local level = math.max(1, math.floor(tonumber(state.level) or 1))
    local wantedLevel = math.clamp(math.floor(tonumber(targetLevel) or maxLevel), 1, maxLevel)
    if level >= maxLevel or level >= wantedLevel then
        return false
    end

    local costs = GetBrawlerUpgradeCost(brawlerId, state)
    if not costs then
        return true
    end
    return GetCoins() >= costs.coins and GetPowerPoints() >= costs.powerPoints
end

local function IsBrawlerAllowedByUpgradeFilter(brawlerId, state, inventory, minRarity, includeRoleMatches)
    if typeof(state) ~= "table" or state.unlocked ~= true then
        return false
    end

    local minScore = BrawlerUpgradeMinRarityScore[minRarity or "Epic"] or BrawlerUpgradeMinRarityScore.Epic
    return minScore <= 0 or GetBrawlerRarityScore(brawlerId) >= minScore
end

local function ScoreBrawlerUpgradeCandidate(brawlerId, state, mode, targetLevel, includeRoleMatches)
    local costs = GetBrawlerUpgradeCost(brawlerId, state)

    local level = math.max(1, math.floor(tonumber(state.level) or 1))
    local selectedSlots = GetBattleSlots()
    local selectedBonus = 0
    if typeof(selectedSlots) == "table" then
        for _, slotId in ipairs(selectedSlots) do
            if slotId == brawlerId then
                selectedBonus = 500000
                break
            end
        end
    end

    local roleBonus = includeRoleMatches == true and IsBrawlerRecommendedForCurrentMap(brawlerId) and 350000 or 0

    local brawler = BrawlerLibrary and BrawlerLibrary.ById and BrawlerLibrary.ById[brawlerId] or nil
    local rarityBonus = BrawlerRarityScore[brawler and brawler.rarity or ""] or 0
    local totalCost = costs and math.max(1, costs.coins + costs.powerPoints * 10) or 1
    local targetBonus = math.max(0, (tonumber(targetLevel) or 11) - level)
    local baseScore = GetBrawlerBaseScore(brawlerId, state) + rarityBonus * 1000 + targetBonus

    if mode == "Epic+ + Roles" then
        return selectedBonus + roleBonus + rarityBonus * 100000 + (100 - level) * 1000 + baseScore / totalCost
    end

    if mode == "Battle Slots" then
        return selectedBonus + roleBonus + baseScore / totalCost
    end

    if mode == "Recommended Roles" then
        return roleBonus + selectedBonus / 2 + baseScore / totalCost
    end

    if mode == "Lowest Level" then
        return (100 - level) * 100000 + roleBonus + selectedBonus + rarityBonus
    end

    return (baseScore + roleBonus + selectedBonus) / totalCost
end

local function ChooseBrawlerUpgradeCandidate(mode, targetLevel, minRarity, includeRoleMatches, skipIds)
    local _, inventory = GetBattleSlots()
    if typeof(inventory) ~= "table" or typeof(inventory.byId) ~= "table" then
        return nil, "inventory unavailable"
    end

    local best = nil
    local matchingLockedByCost = 0
    local matchingMaxedOrTargeted = 0
    local matchingFiltered = 0
    local matchingTemporarilyBlocked = 0
    local firstCostBlockedText = nil
    for brawlerId, state in pairs(inventory.byId) do
        if typeof(brawlerId) == "string" and typeof(state) == "table" and state.unlocked == true then
            if IsBrawlerAllowedByUpgradeFilter(brawlerId, state, inventory, minRarity, includeRoleMatches) then
                matchingFiltered += 1
                local temporaryBlockReason = GetBrawlerUpgradeTemporaryBlockReason(brawlerId)
                if (typeof(skipIds) == "table" and skipIds[brawlerId]) or temporaryBlockReason then
                    matchingTemporarilyBlocked += 1
                elseif CanUpgradeBrawler(brawlerId, state, targetLevel) then
                    local score = ScoreBrawlerUpgradeCandidate(brawlerId, state, mode, targetLevel, includeRoleMatches)
                    if score and (not best or score > best.score) then
                        best = {
                            id = brawlerId,
                            score = score,
                            state = state,
                        }
                    end
                else
                    local costs = GetBrawlerUpgradeCost(brawlerId, state)
                    local level = math.max(1, math.floor(tonumber(state.level) or 1))
                    local maxLevel = tonumber(BrawlerProgressionConfig and BrawlerProgressionConfig.MaxLevel) or 11
                    local wantedLevel = math.clamp(math.floor(tonumber(targetLevel) or maxLevel), 1, maxLevel)
                    if costs and level < maxLevel and level < wantedLevel then
                        matchingLockedByCost += 1
                        if not firstCostBlockedText then
                            firstCostBlockedText = GetBrawlerUpgradeDebugText(brawlerId, state)
                        end
                    else
                        matchingMaxedOrTargeted += 1
                    end
                end
            end
        end
    end

    if best then
        return best.id, "ready", best.state
    end
    if matchingFiltered <= 0 then
        return nil, "no unlocked brawlers match the filter"
    end
    if matchingLockedByCost > 0 then
        return nil, "not enough Coins or PowerPoints | firstBlocked=" .. tostring(firstCostBlockedText or "-")
    end
    if matchingTemporarilyBlocked > 0 then
        return nil, "waiting for Coins or PowerPoints"
    end
    if matchingMaxedOrTargeted > 0 then
        return nil, "matching brawlers are maxed or at target"
    end
    return nil, "no upgrade candidate"
end

local function SmartPurchaseBrawlerUpgrade(brawlerId, state)
    if typeof(brawlerId) ~= "string" or brawlerId == "" then
        return false, "missing brawler id"
    end

    if not PurchaseBrawlerUpgrade then
        return false, "PurchaseBrawlerUpgrade remote missing"
    end

    local ok, result = SafeInvoke(PurchaseBrawlerUpgrade, brawlerId)
    if not ok then
        InvalidateInventorySnapshot()
        HubDebug("BrawlerUpgradeResult", "Remote failed for " .. GetBrawlerUpgradeDebugText(brawlerId, state) .. " | result=" .. tostring(result or "remote call failed"))
        return false, result or "remote call failed"
    end

    if typeof(result) == "table" and result.ok == false then
        InvalidateInventorySnapshot()
        SetBrawlerUpgradeTemporaryBlock(brawlerId, result.message or result.code or "server rejected upgrade")
        HubDebug("BrawlerUpgradeResult", "Server rejected " .. GetBrawlerUpgradeDebugText(brawlerId, state) .. " | result=" .. tostring(result.message or result.code or "server rejected upgrade"))
        return false, result.message or result.code or "server rejected upgrade"
    end

    ClearBrawlerUpgradeTemporaryBlock(brawlerId)
    if typeof(result) == "table" and typeof(result.inventorySnapshot) == "table" then
        InventorySnapshotCache = result.inventorySnapshot
        InventorySnapshotCacheTime = os.clock()
    else
        InvalidateInventorySnapshot()
    end

    HubDebug("BrawlerUpgradeResult", "Bought " .. GetBrawlerUpgradeDebugText(brawlerId, state))
    return true, result
end

