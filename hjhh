local function SafeRequireModule(...)
    local node = ReplicatedStorage
    for _, name in ipairs({ ... }) do
        node = node and node:FindFirstChild(name)
        if not node then
            return nil
        end
    end

    if not node:IsA("ModuleScript") then
        return nil
    end

    local ok, result = pcall(require, node)
    if ok then
        return result
    end
    return nil
end

