task.spawn(function()
    while true do
        if autoEquip then
            print("🐾 EQUIP BEST")
            local args = {}
            pcall(function()
                ReplicatedStorage:WaitForChild("Packages", 9e9):WaitForChild("_Index", 9e9):WaitForChild("sleitnick_knit@1.7.0", 9e9):WaitForChild("knit", 9e9):WaitForChild("Services", 9e9):WaitForChild("PetsService", 9e9):WaitForChild("RE", 9e9):WaitForChild("EquipBest", 9e9):FireServer(unpack(args))
            end)
