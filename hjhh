-- Returns sorted list of unlocked brawlers that CAN be upgraded (have coins+powerpoints)
local function GetUpgradeableBrawlers(inventory, maxCount)
    if not BrawlerProgressionConfig then return {} end
    if typeof(inventory) ~= "table" or typeof(inventory.byId) ~= "table" then return {} end
    local coins     = GetCoins()
    local ppValue   = inventory.currencies and tonumber(inventory.currencies.PowerPoints)
        or inventory.PowerPoints and tonumber(inventory.PowerPoints)
        or GetPlayerNumberValue("PowerPoints")
    local currency = { Coins = coins, PowerPoints = ppValue or 0 }
    local upgradeable = {}
    for brawlerId, state in pairs(inventory.byId) do
        if typeof(state) == "table" and state.unlocked == true then
            local brawler = BrawlerLibrary and BrawlerLibrary.ById and BrawlerLibrary.ById[brawlerId]
            local rarity  = brawler and brawler.rarity or "Rare"
            local level   = tonumber(state.level) or 1
            -- Check max level (11 from BrawlerProgressionConfig.MaxLevel)
            local maxLevel = BrawlerProgressionConfig.MaxLevel or 11
            if level < maxLevel then
                local canUpgrade = pcall(function()
                    return BrawlerProgressionConfig.canUpgradeBrawlerState(state, currency, rarity)
                end)
                if not canUpgrade then
                    canUpgrade = BrawlerProgressionConfig.canUpgradeBrawlerState(state, currency, rarity)
                end
                if canUpgrade then
                    -- Score: higher rarity & level = upgrade first
                    local rarityScore = BrawlerRarityScore[rarity] or 0
                    upgradeable[#upgradeable + 1] = {
                        id = brawlerId,
                        rarity = rarity,
                        level = level,
                        score = rarityScore * 1000 + level,
                    }
                end
            end
        end
    end
    table.sort(upgradeable, function(a, b) return a.score > b.score end)
    local result = {}
    for i = 1, math.min(#upgradeable, maxCount or 5) do
        result[#result + 1] = upgradeable[i]
    end
    return result
end

local function SmartUpgradeBrawlers(maxPerTick)
    if not UpgradeBrawler then return false end
    local _, inventory = GetBattleSlots()
    if typeof(inventory) ~= "table" then return false end
    local upgradeable = GetUpgradeableBrawlers(inventory, maxPerTick or 3)
    local didUpgrade = false
    for _, entry in ipairs(upgradeable) do
        local ok = SafeFire(UpgradeBrawler, entry.id)
        if not ok then
            ok = SafeInvoke(UpgradeBrawler, entry.id)
        end
        if ok then
            didUpgrade = true
            InvalidateInventorySnapshot()
            task.wait(0.2)
        end
    end
    return didUpgrade
end

