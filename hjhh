local function ParseCurrencyAmount(text)
   local sanitized = tostring(text or ""):gsub(",", "")
   local amount = tonumber(sanitized:match("%-?[%d%.]+"))
   return amount or 0
end

local function FindCurrencyLabel(rowNames, countNames)
   for _, rowName in ipairs(rowNames) do
      local row = CurrencyFrame:FindFirstChild(rowName, true)
      if row then
         for _, countName in ipairs(countNames) do
            local countLabel = row:FindFirstChild(countName, true)
            if countLabel then
               return countLabel
            end
         end

         local fallbackLabel = row:FindFirstChildWhichIsA("TextLabel", true)
         if fallbackLabel then
            return fallbackLabel
         end
      end
   end
end

local GoldenCountLabel = FindCurrencyLabel({"GoldenRow"}, {"GoldenCount"})
local PotatoCountLabel = FindCurrencyLabel({"PotatoRow", "PotatoesRow", "NormalRow"}, {"PotatoCount", "Count"})

local function FindStaminaLabel()
   local preferredNames = {
      "StaminaValue",
      "StaminaLabel",
      "StaminaText",
      "CurrentStamina"
   }

   for _, name in ipairs(preferredNames) do
      local label = PotatoGameGui:FindFirstChild(name, true)
      if label and label:IsA("TextLabel") then
         return label
      end
   end

   for _, descendant in ipairs(PotatoGameGui:GetDescendants()) do
      if descendant:IsA("TextLabel") then
         local text = tostring(descendant.Text or "")
         if text:match("^%s*[%d,%.]+%s*/%s*[%d,%.]+%s*$") then
            return descendant
         end
      end
   end
end

local StaminaLabel = FindStaminaLabel()

local function GetStaminaValues()
   if not StaminaLabel or not StaminaLabel.Parent then
      StaminaLabel = FindStaminaLabel()
   end

   if not StaminaLabel then
      return nil, nil
   end

   local currentText, maxText = tostring(StaminaLabel.Text or ""):match("([%d,%.]+)%s*/%s*([%d,%.]+)")
   if not currentText or not maxText then
      return nil, nil
   end

   return ParseCurrencyAmount(currentText), ParseCurrencyAmount(maxText)
end

