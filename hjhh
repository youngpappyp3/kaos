MacroTab:CreateSection("Progression Macro")
MacroTab:CreateLabel("Upgrade + Feed + Ascend")
local ProgressionMacro = false
local MacroLoopDelay = 0.2
local MacroUpgradeDelay = 1
local MacroFeedDelay = 1.5
local MacroAscensionUpgradeDelay = 4
local MacroAscendDelay = 30
local MacroLastUpgradeAt = 0
local MacroLastFeedAt = 0
local MacroLastAscensionUpgradeAt = 0
local MacroLastAscendAt = 0
MacroTab:CreateToggle({
   Name = "Progression Macro V1",
   CurrentValue = false,
   Flag = "ProgressionMacroV1",
   Callback = function(value)
      ProgressionMacro = value

      if ProgressionMacro then
         MacroLastUpgradeAt = os.clock()
         MacroLastFeedAt = os.clock()
         MacroLastAscensionUpgradeAt = os.clock()
         MacroLastAscendAt = os.clock()
         StartManagedLoop("ProgressionMacroV1", function()
            return ProgressionMacro
         end, function()
            local now = os.clock()
            if now - MacroLastUpgradeAt >= MacroUpgradeDelay then
               FireUpgradeBatch()
               MacroLastUpgradeAt = now
            end

            if now - MacroLastFeedAt >= MacroFeedDelay then
               FeedQueen(FeedAmount)
               MacroLastFeedAt = now
            end

            if now - MacroLastAscensionUpgradeAt >= MacroAscensionUpgradeDelay then
               BuyAscensionUpgradeOrder()
               MacroLastAscensionUpgradeAt = os.clock()
            end

            if now - MacroLastAscendAt >= MacroAscendDelay then
               Ascend()
               MacroLastAscendAt = os.clock()
               task.wait(0.25)
               BuyAscensionUpgradeOrder()
               MacroLastAscensionUpgradeAt = os.clock()
            end

            return MacroLoopDelay
         end, 1)
      end
   end,
})

