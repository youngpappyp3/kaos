local function GetBattleSlots()
    local ok, inv = SafeInvoke(GetInventorySnapshot)
    local slots = { "shelly", false, false }

    if ok and typeof(inv) == "table" and typeof(inv.selectedBattleSlots) == "table" then
        slots = inv.selectedBattleSlots
    end

    if BattleConfig and BattleConfig.sanitizeSelectedBrawlerSlots then
        local sanitizedOk, sanitized = pcall(function()
            return BattleConfig.sanitizeSelectedBrawlerSlots(slots, inv)
        end)
        if sanitizedOk and typeof(sanitized) == "table" then
            return sanitized, inv
        end
    end

    return slots, inv
end

local function ExtractMapIdsFromOffer(result)
    if typeof(result) ~= "table" then
        return {}
    end

    local battleState = typeof(result.battleState) == "table" and result.battleState or result
    local offer = typeof(battleState.pendingMapOffer) == "table" and battleState.pendingMapOffer or result.pendingMapOffer

    if typeof(offer) == "table" and typeof(offer.mapIds) == "table" then
        return offer.mapIds
    end

    if typeof(result.mapIds) == "table" then
        return result.mapIds
    end

    if typeof(result.maps) == "table" then
        local ids = {}
        for _, map in ipairs(result.maps) do
            if typeof(map) == "string" then
                ids[#ids + 1] = map
            elseif typeof(map) == "table" and typeof(map.id or map.mapId) == "string" then
                ids[#ids + 1] = map.id or map.mapId
            end
        end
        return ids
    end

    return {}
end

local function GetMapConfig(mapId)
    if BattleConfig and BattleConfig.getMap then
        local ok, map = pcall(function()
            return BattleConfig.getMap(mapId)
        end)
        if ok and typeof(map) == "table" then
            return map
        end
    end

    if BattleConfig and typeof(BattleConfig.Maps) == "table" and typeof(BattleConfig.Maps[mapId]) == "table" then
        return BattleConfig.Maps[mapId]
    end

    return {
        id = mapId,
        order = BattleMapOrder[mapId] or 0,
        trophyReward = BattleMapOrder[mapId] or 0,
        baseWinChance = 0,
    }
end

local function GetMapPreview(mapId, slots, inventory)
    if BattleConfig and BattleConfig.calculatePreview then
        local ok, preview = pcall(function()
            return BattleConfig.calculatePreview(mapId, slots, inventory)
        end)
        if ok and typeof(preview) == "table" then
            return preview
        end
    end
    return nil
end

local function IsBetterBattleMap(candidate, current, mode)
    if not current then
        return true
    end

    if mode == "Best Reward" then
        if candidate.trophyReward == current.trophyReward then
            if candidate.winChance == current.winChance then
                return candidate.order > current.order
            end
            return candidate.winChance > current.winChance
        end
        return candidate.trophyReward > current.trophyReward
    end

    if candidate.winChance == current.winChance then
        if candidate.trophyReward == current.trophyReward then
            return candidate.order > current.order
        end
        return candidate.trophyReward > current.trophyReward
    end
    return candidate.winChance > current.winChance
end

local function ChooseBattleMap(mapIds, slots, inventory, mode, fallbackMap)
    if mode == "Manual Dropdown" then
        return fallbackMap
    end

    local best = nil
    for _, mapId in ipairs(mapIds or {}) do
        if typeof(mapId) == "string" then
            local map = GetMapConfig(mapId)
            local preview = GetMapPreview(mapId, slots, inventory)
            local candidate = {
                mapId = mapId,
                order = tonumber(map and map.order) or BattleMapOrder[mapId] or 0,
                trophyReward = tonumber(preview and preview.trophyReward) or tonumber(map and map.trophyReward) or 0,
                winChance = tonumber(preview and preview.winChance) or tonumber(map and map.baseWinChance) or 0,
            }

            if IsBetterBattleMap(candidate, best, mode) then
                best = candidate
            end
        end
    end

    return (best and best.mapId) or fallbackMap
end

local function RequestAndStartSmartBattle(mode, fallbackMap)
    local existingMapIds = {}
    local stateOk, state = SafeInvoke(GetBattleState)
    if stateOk and typeof(state) == "table" then
        if typeof(state.completedResult) == "table" then
            SafeInvoke(AcknowledgeBattleResult, { deferBoxRewards = true })
            return true, 1
        end

        if typeof(state.activeBattle) == "table" then
            return true, 3
        end

        existingMapIds = ExtractMapIdsFromOffer(state)
    end

    local slots, inventory = GetBattleSlots()
    local mapsOk, mapsResult = SafeInvoke(RequestBattleMaps)
    if not mapsOk or typeof(mapsResult) ~= "table" then
        return false, nil
    end

    local mapIds = ExtractMapIdsFromOffer(mapsResult)
    if #mapIds <= 0 then
        mapIds = existingMapIds
    end

    if mode ~= "Manual Dropdown" and #mapIds <= 0 then
        return false, nil
    end

    local chosenMap = ChooseBattleMap(mapIds, slots, inventory, mode, fallbackMap)
    if typeof(chosenMap) ~= "string" then
        return false, nil
    end

    local startOk = SafeInvoke(StartBattle, chosenMap, slots)
    return startOk, chosenMap
end

