local function GetBattleSlots()
    local inv
    local now = os.clock()
    if InventorySnapshotCache and now - InventorySnapshotCacheTime <= INVENTORY_CACHE_SECONDS then
        inv = InventorySnapshotCache
    else
        local ok, snapshot = SafeInvoke(GetInventorySnapshot)
        if ok and typeof(snapshot) == "table" then
            inv = snapshot
            InventorySnapshotCache = snapshot
            InventorySnapshotCacheTime = now
        end
    end

    local slots = { "shelly", false, false }

    if typeof(inv) == "table" and typeof(inv.selectedBattleSlots) == "table" then
        slots = inv.selectedBattleSlots
    end

    if BattleConfig and BattleConfig.sanitizeSelectedBrawlerSlots then
        local sanitizedOk, sanitized = pcall(function()
            return BattleConfig.sanitizeSelectedBrawlerSlots(slots, inv)
        end)
        if sanitizedOk and typeof(sanitized) == "table" then
            return sanitized, inv
        end
    end

    return slots, inv
end

local function GetBrawlerBaseScore(brawlerId, state)
    local level = tonumber(state and state.level) or 1
    local trophies = tonumber(state and state.trophies) or 0
    local brawler = BrawlerLibrary and BrawlerLibrary.ById and BrawlerLibrary.ById[brawlerId] or nil
    local rarityScore = 0

    if brawler and brawler.rarity then
        local rarity = tostring(brawler.rarity)
        rarityScore = BrawlerRarityScore[rarity] or 0
    end

    return level * 100000 + trophies * 10 + rarityScore
end

local function GetUnlockedBrawlerCandidates(inventory)
    local candidates = {}
    if typeof(inventory) ~= "table" or typeof(inventory.byId) ~= "table" then
        return candidates
    end

    for brawlerId, state in pairs(inventory.byId) do
        if typeof(brawlerId) == "string" and typeof(state) == "table" and state.unlocked == true then
            candidates[#candidates + 1] = {
                id = brawlerId,
                score = GetBrawlerBaseScore(brawlerId, state),
            }
        end
    end

    table.sort(candidates, function(a, b)
        return a.score > b.score
    end)

    local trimmed = {}
    for i = 1, math.min(#candidates, 10) do
        trimmed[#trimmed + 1] = candidates[i]
    end
    return trimmed
end

local function ScoreBattleSlots(mapId, slots, inventory)
    local preview = GetMapPreview(mapId, slots, inventory)
    if preview then
        return (tonumber(preview.winChance) or 0) * 100000 + (tonumber(preview.trophyReward) or 0), preview
    end

    local score = 0
    for _, slot in ipairs(slots) do
        if typeof(slot) == "string" and inventory and inventory.byId then
            score += GetBrawlerBaseScore(slot, inventory.byId[slot] or {})
        end
    end
    return score, nil
end

local function GetMapRecommendedClasses(mapId)
    local mapCfg = GetMapConfig(mapId)
    if mapCfg and typeof(mapCfg.recommendedClasses) == "table" then
        local set = {}
        for _, cls in ipairs(mapCfg.recommendedClasses) do
            set[cls] = true
        end
        return set
    end
    return {}
end

local function GetBrawlerBaseScoreForMap(brawlerId, state, recommendedClassSet)
    local baseScore = GetBrawlerBaseScore(brawlerId, state)
    -- Add bonus if this brawler's class matches a recommended class for the map
    local brawler = BrawlerLibrary and BrawlerLibrary.ById and BrawlerLibrary.ById[brawlerId]
    if brawler and brawler.classKey and recommendedClassSet[brawler.classKey] then
        baseScore = baseScore + 500000  -- large bonus to prefer role-matched brawlers
    end
    return baseScore
end

local function GetUnlockedBrawlerCandidatesForMap(inventory, mapId)
    local recClasses = GetMapRecommendedClasses(mapId)
    local candidates = {}
    if typeof(inventory) ~= "table" or typeof(inventory.byId) ~= "table" then
        return candidates
    end
    for brawlerId, state in pairs(inventory.byId) do
        if typeof(brawlerId) == "string" and typeof(state) == "table" and state.unlocked == true then
            candidates[#candidates + 1] = {
                id = brawlerId,
                score = GetBrawlerBaseScoreForMap(brawlerId, state, recClasses),
            }
        end
    end
    table.sort(candidates, function(a, b) return a.score > b.score end)
    local trimmed = {}
    for i = 1, math.min(#candidates, 10) do
        trimmed[#trimmed + 1] = candidates[i]
    end
    return trimmed
end

local function ChooseBestBattleSlotsForMap(mapId, inventory)
    local candidates = GetUnlockedBrawlerCandidatesForMap(inventory, mapId)
    if #candidates <= 0 then
        candidates = GetUnlockedBrawlerCandidates(inventory)
    end
    if #candidates <= 0 then
        return { "shelly", false, false }, nil
    end

    local bestSlots = nil
    local bestScore = nil
    local bestPreview = nil

    local function consider(slots)
        local padded = { slots[1] or false, slots[2] or false, slots[3] or false }
        local score, preview = ScoreBattleSlots(mapId, padded, inventory)
        -- Add class bonus to combined score
        local recClasses = GetMapRecommendedClasses(mapId)
        for _, brawlerId in ipairs(padded) do
            if typeof(brawlerId) == "string" then
                local brawler = BrawlerLibrary and BrawlerLibrary.ById and BrawlerLibrary.ById[brawlerId]
                if brawler and brawler.classKey and recClasses[brawler.classKey] then
                    score = score + 50000
                end
            end
        end
        if not bestScore or score > bestScore then
            bestScore = score
            bestSlots = padded
            bestPreview = preview
        end
    end

    for i = 1, #candidates do
        consider({ candidates[i].id })
        for j = i + 1, #candidates do
            consider({ candidates[i].id, candidates[j].id })
            for k = j + 1, #candidates do
                consider({ candidates[i].id, candidates[j].id, candidates[k].id })
            end
        end
    end

    return bestSlots or { candidates[1].id, false, false }, bestPreview
end

local function ExtractMapIdsFromOffer(result)
    if typeof(result) ~= "table" then
        return {}
    end

    local battleState = typeof(result.battleState) == "table" and result.battleState or result
    local offer = typeof(battleState.pendingMapOffer) == "table" and battleState.pendingMapOffer or result.pendingMapOffer

    if typeof(offer) == "table" and typeof(offer.mapIds) == "table" then
        return offer.mapIds
    end

    if typeof(result.mapIds) == "table" then
        return result.mapIds
    end

    if typeof(result.maps) == "table" then
        local ids = {}
        for _, map in ipairs(result.maps) do
            if typeof(map) == "string" then
                ids[#ids + 1] = map
            elseif typeof(map) == "table" and typeof(map.id or map.mapId) == "string" then
                ids[#ids + 1] = map.id or map.mapId
            end
        end
        return ids
    end

    return {}
end

local function GetMapConfig(mapId)
    if BattleConfig and BattleConfig.getMap then
        local ok, map = pcall(function()
            return BattleConfig.getMap(mapId)
        end)
        if ok and typeof(map) == "table" then
            return map
        end
    end

    if BattleConfig and typeof(BattleConfig.Maps) == "table" and typeof(BattleConfig.Maps[mapId]) == "table" then
        return BattleConfig.Maps[mapId]
    end

    return {
        id = mapId,
        order = BattleMapOrder[mapId] or 0,
        trophyReward = BattleMapOrder[mapId] or 0,
        baseWinChance = 0,
    }
end

function GetMapPreview(mapId, slots, inventory)
    if BattleConfig and BattleConfig.calculatePreview then
        local ok, preview = pcall(function()
            return BattleConfig.calculatePreview(mapId, slots, inventory)
        end)
        if ok and typeof(preview) == "table" then
            return preview
        end
    end
    return nil
end

local function IsBetterBattleMap(candidate, current, mode)
    if not current then
        return true
    end

    if mode == "Best Reward" then
        if candidate.trophyReward == current.trophyReward then
            if candidate.winChance == current.winChance then
                return candidate.order > current.order
            end
            return candidate.winChance > current.winChance
        end
        return candidate.trophyReward > current.trophyReward
    end

    if candidate.winChance == current.winChance then
        if candidate.trophyReward == current.trophyReward then
            return candidate.order > current.order
        end
        return candidate.trophyReward > current.trophyReward
    end
    return candidate.winChance > current.winChance
end

local function ChooseBattleMap(mapIds, slots, inventory, mode, fallbackMap)
    if mode == "Manual Dropdown" then
        return fallbackMap
    end

    local best = nil
    for _, mapId in ipairs(mapIds or {}) do
        if typeof(mapId) == "string" then
            local map = GetMapConfig(mapId)
            local preview = GetMapPreview(mapId, slots, inventory)
            local candidate = {
                mapId = mapId,
                order = tonumber(map and map.order) or BattleMapOrder[mapId] or 0,
                trophyReward = tonumber(preview and preview.trophyReward) or tonumber(map and map.trophyReward) or 0,
                winChance = tonumber(preview and preview.winChance) or tonumber(map and map.baseWinChance) or 0,
            }

            if IsBetterBattleMap(candidate, best, mode) then
                best = candidate
            end
        end
    end

    return (best and best.mapId) or fallbackMap
end

local function RequestAndStartSmartBattle(mode, fallbackMap, autoEquipBest)
    local existingMapIds = {}
    local stateOk, state = SafeInvoke(GetBattleState)
    if stateOk and typeof(state) == "table" then
        if typeof(state.completedResult) == "table" then
            SetBattleResult(state.completedResult)
            SetBattleStatus("Completed - collecting")
            SafeInvoke(AcknowledgeBattleResult, { deferBoxRewards = true })
            return true, 1
        end

        if typeof(state.activeBattle) == "table" then
            local mapId = tostring(state.activeBattle.mapId or "?")
            local endTime = tonumber(state.activeBattle.endTime)
            if endTime then
                SetBattleStatus("Active: " .. mapId .. " | ends " .. tostring(math.max(0, math.floor(endTime - os.time()))) .. "s")
            else
                SetBattleStatus("Active: " .. mapId)
            end
            return true, 3
        end

        existingMapIds = ExtractMapIdsFromOffer(state)
    end

    local slots, inventory = GetBattleSlots()
    local mapsOk, mapsResult = SafeInvoke(RequestBattleMaps)
    if not mapsOk or typeof(mapsResult) ~= "table" then
        return false, nil
    end

    local mapIds = ExtractMapIdsFromOffer(mapsResult)
    if #mapIds <= 0 then
        mapIds = existingMapIds
    end

    if mode ~= "Manual Dropdown" and #mapIds <= 0 then
        return false, nil
    end

    local chosenMap = ChooseBattleMap(mapIds, slots, inventory, mode, fallbackMap)
    if typeof(chosenMap) ~= "string" then
        SetBattleStatus("No valid map")
        return false, nil
    end

    if autoEquipBest then
        local bestSlots = ChooseBestBattleSlotsForMap(chosenMap, inventory)
        if typeof(bestSlots) == "table" then
            slots = bestSlots
            if SafeFire(SetSelectedBattleSlots, slots) then
                InvalidateInventorySnapshot()
            end
            task.wait(0.15)
        end
    end

    SetBattleOffer(mapIds, chosenMap)
    SetBattleSlots(slots)
    SetBattleStatus("Starting: " .. chosenMap)
    local startOk = SafeInvoke(StartBattle, chosenMap, slots)
    if startOk then
        SetBattleStatus("Started: " .. chosenMap)
    else
        SetBattleStatus("Start failed: " .. chosenMap)
    end
    return startOk, chosenMap
end

local function RefreshBattleStatus()
    local stateOk, state = SafeInvoke(GetBattleState)
    if not stateOk or typeof(state) ~= "table" then
        SetBattleStatus("Refresh failed")
        return nil
    end

    if typeof(state.completedResult) == "table" then
        SetBattleResult(state.completedResult)
        SetBattleStatus("Completed - ready to collect")
        return state
    end

    if typeof(state.activeBattle) == "table" then
        local mapId = tostring(state.activeBattle.mapId or "?")
        local endTime = tonumber(state.activeBattle.endTime)
        if endTime then
            SetBattleStatus("Active: " .. mapId .. " | ends " .. tostring(math.max(0, math.floor(endTime - os.time()))) .. "s")
        else
            SetBattleStatus("Active: " .. mapId)
        end
        return state
    end

    SetBattleStatus("Idle")
    SetBattleOffer(ExtractMapIdsFromOffer(state), nil)
    return state
end

local function GetPlayerNumberValue(name)
    local value = NumberValueCache[name]
    if not value or value.Parent ~= player then
        value = player:FindFirstChild(name)
        NumberValueCache[name] = value
    end

    if value and (value:IsA("NumberValue") or value:IsA("IntValue")) then
        return tonumber(value.Value) or 0
    end
    return 0
end

