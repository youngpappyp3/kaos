do
CodesTab:CreateSection("Auto Redeem Codes")

local KnownCodes = {}
local CodeSourceUrl = ""

local function AddCode(codeList, seen, code)
    if typeof(code) ~= "string" then
        return
    end

    code = code:match("^%s*(.-)%s*$")
    if code == "" or seen[code] then
        return
    end

    seen[code] = true
    codeList[#codeList + 1] = code
end

local function ExtractCodesFromText(text, codeList, seen)
    if typeof(text) ~= "string" then
        return
    end

    for code in string.gmatch(text, "[A-Za-z0-9_%-]+") do
        if #code >= 3 and #code <= 40 then
            AddCode(codeList, seen, code)
        end
    end
end

local function ExtractCodesFromTable(value, codeList, seen, depth)
    if typeof(value) ~= "table" or depth > 4 then
        return
    end

    for key, child in pairs(value) do
        local keyText = tostring(key):lower()
        if typeof(child) == "string" then
            if keyText:find("code") or keyText:find("redeem") or keyText:find("promo") or keyText:find("name") then
                AddCode(codeList, seen, child)
            end
        elseif typeof(child) == "table" then
            ExtractCodesFromTable(child, codeList, seen, depth + 1)
        end
    end
end

local function GetCodesFromGameModules(codeList, seen)
    for _, module in ipairs(ReplicatedStorage:GetDescendants()) do
        if module:IsA("ModuleScript") then
            local name = module.Name:lower()
            if name:find("code") or name:find("redeem") or name:find("promo") then
                local ok, result = pcall(require, module)
                if ok then
                    if typeof(result) == "table" then
                        ExtractCodesFromTable(result, codeList, seen, 0)
                    elseif typeof(result) == "string" then
                        ExtractCodesFromText(result, codeList, seen)
                    end
                end
            end
        end
    end
end

local function GetCodesFromUrl(codeList, seen)
    if CodeSourceUrl == "" then
        return
    end

    local ok, body = pcall(function()
        return game:HttpGet(CodeSourceUrl)
    end)
    if ok and typeof(body) == "string" then
        ExtractCodesFromText(body, codeList, seen)
    end
end

local function BuildCodeList()
    local codeList = {}
    local seen = {}

    for _, code in ipairs(KnownCodes) do
        AddCode(codeList, seen, code)
    end

    GetCodesFromGameModules(codeList, seen)
    GetCodesFromUrl(codeList, seen)
    return codeList
end

local function RedeemCodeAndNotify(code)
    local ok, result = SafeInvoke(RedeemCode, code)
    if ok and typeof(result) == "table" and result.ok == true then
        SafeNotify({
            Title   = "Code Redeemed",
            Content = "Successfully redeemed: " .. code,
            Duration = 3,
        })
        return true
    end

    local msg = "Failed"
    if typeof(result) == "table" and result.message then
        msg = result.message
    end
    SafeNotify({
        Title   = "Code Failed",
        Content = code .. " - " .. msg,
        Duration = 3,
    })
    return false
end

CodesTab:CreateInput({
    Name                = "Enter Codes (comma-separated)",
    PlaceholderText     = "code1, code2, code3",
    RemoveTextAfterFocusLost = false,
    Callback            = function(v)
        KnownCodes = {}
        for code in string.gmatch(v, "[^,%s]+") do
            table.insert(KnownCodes, code)
        end
    end,
})

CodesTab:CreateInput({
    Name                = "Code List URL",
    PlaceholderText     = "raw GitHub txt/json/list URL...",
    RemoveTextAfterFocusLost = false,
    Callback            = function(v)
        CodeSourceUrl = tostring(v or ""):match("^%s*(.-)%s*$")
    end,
})

CodesTab:CreateButton({
    Name     = "Redeem All Codes",
    Callback = function()
        local codes = BuildCodeList()
        if #codes <= 0 then
            SafeNotify({
                Title   = "No Codes",
                Content = "No manual, module, or URL codes found.",
                Duration = 3,
            })
            return
        end

        SafeNotify({
            Title   = "Codes",
            Content = "Trying " .. tostring(#codes) .. " code(s).",
            Duration = 3,
        })

        for _, code in ipairs(codes) do
            RedeemCodeAndNotify(code)
            task.wait(1)
        end
    end,
})

CodesTab:CreateInput({
    Name                = "Redeem Single Code",
    PlaceholderText     = "Enter code...",
    RemoveTextAfterFocusLost = false,
    Callback            = function(v)
        if v == "" then return end
        RedeemCodeAndNotify(v)
    end,
})

end

