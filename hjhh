-- ============================================================
--  MACRO TAB  –  ClickerMax  (all-in-one, optimal order)
--
--  ORDER RATIONALE:
--    1. ClickPower upgrade  — boost each tap first
--    2. CoinGenerator upgrade — passive income
--    3. Auto tap            — earn with boosted value
--    4. Rebirth             — configurable timer for multipliers
-- ============================================================
MacroTab:CreateSection("ClickerMax Macro")
MacroTab:CreateLabel("Click → Upgrades → Rebirth")

local MacroRunning      = false
local MacroRebirthDelay = 60
local MacroLastRebirth  = 0

MacroTab:CreateInput({
    Name                = "Macro Rebirth Delay (s)",
    PlaceholderText     = "Default: 60",
    RemoveTextAfterFocusLost = false,
    Callback            = function(v) MacroRebirthDelay = tonumber(v) or 60 end,
})

MacroTab:CreateToggle({
    Name         = "ClickerMax Macro",
    CurrentValue = false,
    Flag         = "ClickerMaxMacro",
    Callback     = function(v)
        MacroRunning     = v
        MacroLastRebirth = os.clock()

        if MacroRunning then
            StartManagedLoop("ClickerMaxMacro", function() return MacroRunning end, function()
                local now = os.clock()

                -- 1. Buy ClickPower
                PurchaseUpgrade:InvokeServer("ClickPower", "single")
                task.wait(0.05)

                -- 2. Buy CoinGenerator
                PurchaseUpgrade:InvokeServer("CoinGenerator", "single")
                task.wait(0.05)

                -- 3. Tap / click
                ClickerTap:FireServer()
                task.wait(0.05)

                -- 4. Rebirth (every MacroRebirthDelay seconds)
                if now - MacroLastRebirth >= MacroRebirthDelay then
                    PurchaseRebirth:InvokeServer()
                    MacroLastRebirth = now
                    task.wait(0.5)
                end

                return 0   -- loop as fast as possible
            end, 1)
        end
    end,
})

