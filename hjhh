            end
        end
        return nil
    end

    local best = nil
    for _, entry in ipairs(UpgradeList) do
        local candidate = GetUpgradeCandidate(entry[1], snapshot)
        if candidate then
            if not best then
                best = candidate
            elseif mode == "Cheapest" and candidate.price < best.price then
                best = candidate
            elseif mode == "Best Value" and candidate.value > best.value then
                best = candidate
            end
        end
    end

    return best and best.id or nil
end

