-- Arrayfield Hub - Tap + Hatch + Rebirth + Equip + Anti-AFK (Mobile Ready)

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local VirtualUser = game:GetService("VirtualUser")
local LocalPlayer = Players.LocalPlayer

local Rayfield = loadstring(game:HttpGet('https://raw.githubusercontent.com/UI-Interface/CustomFIeld/main/RayField.lua'))()

local Window = Rayfield:CreateWindow({
    Name = "Arrayfield Hub",
    LoadingTitle = "Full Farm",
    LoadingSubtitle = "by Arrays",
    KeySystem = false,
})

local MainTab = Window:CreateTab("Main")
local SettingsTab = Window:CreateTab("Settings")

-- Variables
local autoTap = false
local autoHatch = false
local autoRebirth = false
local autoEquip = false
local selectedEgg = "Basic"
local hatchAmount = 1
local rebirthAmount = 1   -- changeable

-- ==================== MAIN TAB ====================
MainTab:CreateSection("Auto Farming")

MainTab:CreateToggle({
    Name = "Auto Tap (0.1s)",
    CurrentValue = false,
    Callback = function(v) autoTap = v end,
})

MainTab:CreateToggle({
    Name = "Auto Hatch",
    CurrentValue = false,
    Callback = function(v) autoHatch = v end,
})

MainTab:CreateDropdown({
    Name = "Select Egg",
    Options = {"Basic", "Beach", "Hype", "Ice", "Lava", "Mountain", "Mushroom", "Question", "Release", "Sakura"},
    CurrentOption = {"Basic"},
    Callback = function(opt) selectedEgg = opt[1] end,
})

MainTab:CreateSlider({
    Name = "Hatch Amount",
    Range = {1, 20},
    Increment = 1,
    CurrentValue = 1,
    Callback = function(v) hatchAmount = v end,
})

MainTab:CreateToggle({
    Name = "Auto Rebirth",
    CurrentValue = false,
    Callback = function(v) autoRebirth = v end,
})

MainTab:CreateSlider({
    Name = "Rebirth Amount (how many times)",
    Range = {1, 10},
    Increment = 1,
    CurrentValue = 1,
    Callback = function(v) rebirthAmount = v end,
})

MainTab:CreateToggle({
    Name = "Auto Equip Best Pets",
    CurrentValue = false,
    Callback = function(v) autoEquip = v end,
})

-- ==================== SETTINGS TAB ====================
SettingsTab:CreateSection("Misc")

SettingsTab:CreateToggle({
    Name = "Enable Anti-AFK",
    CurrentValue = false,
    Callback = function(v)
        if v then
            LocalPlayer.Idled:Connect(function()
                VirtualUser:Button2Down(Vector2.new(), workspace.CurrentCamera.CFrame)
                task.wait(1)
                VirtualUser:Button2Up(Vector2.new(), workspace.CurrentCamera.CFrame)
            end)
            Rayfield:Notify("Anti-AFK", "Enabled", 3)
        end
    end,
})

-- ==================== LOOPS ====================

-- Auto Tap
task.spawn(function()
    while true do
        if autoTap then
            local args = {}
            pcall(function()
                ReplicatedStorage:WaitForChild("Packages", 9e9):WaitForChild("_Index", 9e9):WaitForChild("sleitnick_knit@1.7.0", 9e9):WaitForChild("knit", 9e9):WaitForChild("Services", 9e9):WaitForChild("TapsService", 9e9):WaitForChild("RE", 9e9):WaitForChild("Taps", 9e9):FireServer(unpack(args))
            end)
        end
        task.wait(0.1)
    end
end)

-- Auto Hatch (your exact method)
task.spawn(function()
    while true do
        if autoHatch then
            print("🥚 HATCH → " .. selectedEgg .. " x" .. hatchAmount)
            local args = { [1] = selectedEgg, [2] = hatchAmount }
            pcall(function()
                ReplicatedStorage:WaitForChild("Packages", 9e9):WaitForChild("_Index", 9e9):WaitForChild("sleitnick_knit@1.7.0", 9e9):WaitForChild("knit", 9e9):WaitForChild("Services", 9e9):WaitForChild("EggsService", 9e9):WaitForChild("RE", 9e9):WaitForChild("HatchEggs", 9e9):FireServer(unpack(args))
            end)
        end
        task.wait(1.8)
    end
end)

-- Auto Rebirth (your exact method + changeable number)
task.spawn(function()
    while true do
        if autoRebirth then
            print("♻️ REBIRTH → " .. rebirthAmount .. " times")
            local args = { [1] = rebirthAmount }
            pcall(function()
                ReplicatedStorage:WaitForChild("Packages", 9e9):WaitForChild("_Index", 9e9):WaitForChild("sleitnick_knit@1.7.0", 9e9):WaitForChild("knit", 9e9):WaitForChild("Services", 9e9):WaitForChild("RebirthsService", 9e9):WaitForChild("RE", 9e9):WaitForChild("Rebirth", 9e9):FireServer(unpack(args))
            end)
        end
        task.wait(5) -- safe delay for rebirth
    end
end)

