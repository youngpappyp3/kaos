-- Arrayfield Hub - Updated with Tabs, No Key, Exact Remotes, Safe Loops

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local VirtualUser = game:GetService("VirtualUser")
local LocalPlayer = Players.LocalPlayer

-- Load Rayfield
local Rayfield = loadstring(game:HttpGet('https://raw.githubusercontent.com/UI-Interface/CustomFIeld/main/RayField.lua'))()

local Window = Rayfield:CreateWindow({
    Name = "Arrayfield Hub",
    LoadingTitle = "Arrayfield Suite",
    LoadingSubtitle = "by Arrays",
    ConfigurationSaving = {
        Enabled = true,
        FolderName = nil,
        FileName = "ArrayfieldHub"
    },
    KeySystem = false,  -- Disabled
})

-- Tabs
local MainTab = Window:CreateTab("Main", 4483362458)
local SettingsTab = Window:CreateTab("Settings")

-- Sections
local AutoFarmSection = MainTab:CreateSection("Auto Farm", false)
local HatchSection = MainTab:CreateSection("Auto Hatch", false)
local MiscSection = SettingsTab:CreateSection("Misc / Anti-AFK", false)

-- Variables
local autoTap = false
local autoRebirth = false
local autoHatch = false
local autoEquip = false
local selectedEgg = "Basic"
local hatchAmount = 1
local antiAFKEnabled = false

-- ==================== TOGGLES & INPUTS ====================

MainTab:CreateToggle({
    Name = "Auto Tap (0.1s delay)",
    CurrentValue = false,
    Callback = function(Value)
        autoTap = Value
        Rayfield:Notify("Auto Tap", Value and "Enabled" or "Disabled", 3)
    end,
})

MainTab:CreateToggle({
    Name = "Auto Rebirth",
    CurrentValue = false,
    Callback = function(Value)
        autoRebirth = Value
        Rayfield:Notify("Auto Rebirth", Value and "Enabled" or "Disabled", 3)
    end,
})

MainTab:CreateToggle({
    Name = "Auto Hatch",
    CurrentValue = false,
    Callback = function(Value)
        autoHatch = Value
        Rayfield:Notify("Auto Hatch", Value and "Enabled" or "Disabled", 3)
    end,
})

MainTab:CreateToggle({
    Name = "Auto Equip Best",
    CurrentValue = false,
    Callback = function(Value)
        autoEquip = Value
        Rayfield:Notify("Auto Equip Best", Value and "Enabled" or "Disabled", 3)
    end,
})

-- Egg Dropdown (add your real egg names here - check game Folders or Remote calls in F9)
HatchSection:CreateDropdown({
    Name = "Select Egg",
    Options = {"Basic", "Rare", "Epic", "Mythical", "Legendary", "Godly", "Premium"}, -- ← EDIT THESE TO MATCH YOUR GAME
    CurrentOption = {"Basic"},
    MultipleOptions = false,
    Callback = function(Option)
        selectedEgg = Option[1]
        print("Selected Egg: " .. selectedEgg)
    end,
})

HatchSection:CreateInput({
    Name = "Hatch Amount",
    PlaceholderText = "Enter number (1-50 recommended)",
    RemoveTextAfterFocusLost = false,
    NumbersOnly = true,
    Callback = function(Text)
        local num = tonumber(Text)
        if num and num > 0 then
            hatchAmount = num
            print("Hatch Amount set to: " .. hatchAmount)
        else
            hatchAmount = 1
        end
    end,
})

-- Keybind example (toggle Auto Tap with T)
MainTab:CreateKeybind({
    Name = "Toggle Auto Tap",
    CurrentKeybind = "T",
    HoldToInteract = false,
    Callback = function(Keybind)
        autoTap = not autoTap
        Rayfield:Notify("Auto Tap", autoTap and "Toggled ON" or "Toggled OFF", 2)
    end,
})

-- Anti-AFK Toggle
SettingsTab:CreateToggle({
    Name = "Anti-AFK",
    CurrentValue = false,
    Callback = function(Value)
        antiAFKEnabled = Value
        if Value then
            if not LocalPlayer.Idled then return end
            LocalPlayer.Idled:Connect(function()
                VirtualUser:Button2Down(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
                task.wait(1)
                VirtualUser:Button2Up(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
            end)
            Rayfield:Notify("Anti-AFK", "Enabled - No more idle kicks!", 4)
        else
            Rayfield:Notify("Anti-AFK", "Disabled", 3)
        end
    end,
})

-- ==================== MAIN LOOP ====================
RunService.Heartbeat:Connect(function()  -- Heartbeat is fine for loops
    if autoTap then
        local args = {}
        pcall(function()
            game:GetService("ReplicatedStorage"):WaitForChild("Packages", 9e9):WaitForChild("_Index", 9e9):WaitForChild("sleitnick_knit@1.7.0", 9e9):WaitForChild("knit", 9e9):WaitForChild("Services", 9e9):WaitForChild("TapsService", 9e9):WaitForChild("RE", 9e9):WaitForChild("Taps", 9e9):FireServer(unpack(args))
        end)
        task.wait(0.1)  -- Your requested 0.1s delay
    end

    if autoRebirth then
        local args = { [1] = 1 }
        pcall(function()
            game:GetService("ReplicatedStorage"):WaitForChild("Packages", 9e9):WaitForChild("_Index", 9e9):WaitForChild("sleitnick_knit@1.7.0", 9e9):WaitForChild("knit", 9e9):WaitForChild("Services", 9e9):WaitForChild("RebirthsService", 9e9):WaitForChild("RE", 9e9):WaitForChild("Rebirth", 9e9):FireServer(unpack(args))
        end)
        task.wait(3)  -- Safe delay for rebirth
    end

    if autoHatch then
        local args = { [1] = selectedEgg, [2] = hatchAmount }
        pcall(function()
            game:GetService("ReplicatedStorage"):WaitForChild("Packages", 9e9):WaitForChild("_Index", 9e9):WaitForChild("sleitnick_knit@1.7.0", 9e9):WaitForChild("knit", 9e9):WaitForChild("Services", 9e9):WaitForChild("EggsService", 9e9):WaitForChild("RE", 9e9):WaitForChild("HatchEggs", 9e9):FireServer(unpack(args))
        end)
        task.wait(1.8)  -- Safe hatch rate
    end

    if autoEquip then
        local args = {}
        pcall(function()
            game:GetService("ReplicatedStorage"):WaitForChild("Packages", 9e9):WaitForChild("_Index", 9e9):WaitForChild("sleitnick_knit@1.7.0", 9e9):WaitForChild("knit", 9e9):WaitForChild("Services", 9e9):WaitForChild("PetsService", 9e9):WaitForChild("RE", 9e9):WaitForChild("EquipBest", 9e9):FireServer(unpack(args))
        end)
        task.wait(4)  -- Equip best doesn't need to spam
    end
end)

print("Arrayfield Hub LOADED - Tabs & features active!")
Rayfield:Notify("Hub Ready", "Use Main tab for farming, Settings for anti-AFK", 5)
