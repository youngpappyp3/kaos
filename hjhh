local RemoteCache = {}
local function GetRemote(name, timeout)
    if RemoteCache[name] ~= nil then
        return RemoteCache[name] or nil
    end
    local remote = Remotes:FindFirstChild(name)
    if not remote and timeout and timeout > 0 then
        remote = Remotes:WaitForChild(name, timeout)
    end
    RemoteCache[name] = remote or false
    return remote
end

local function SafeInvoke(remoteOrName, ...)
    local remote = typeof(remoteOrName) == "string" and GetRemote(remoteOrName) or remoteOrName
    if not remote then
        return false, nil
    end
    if remote:IsA("RemoteFunction") then
        return pcall(function(...)
            return remote:InvokeServer(...)
        end, ...)
    end
    if remote:IsA("RemoteEvent") then
        return pcall(function(...)
            remote:FireServer(...)
            return true
        end, ...)
    end
    return false, nil
end

local function SafeFire(remoteOrName, ...)
    local ok = SafeInvoke(remoteOrName, ...)
    return ok == true
end

