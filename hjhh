                if now - lastReward >= 30 then
                    lastReward = now
                    MacroClaimRewards()
                end

                return 0.1
            end, 1)
        end
    end,
})

MacroTab:CreateToggle({
    Name         = "Ranked Farm Macro",
    CurrentValue = false,
    Flag         = "RankedFarmMacro",
    Callback     = function(v)
        RankedFarmMacroRunning = v
        local lastReward = 0

        if RankedFarmMacroRunning then
            StopOtherMacros("RankedFarmMacro")
            StartManagedLoop("RankedFarmMacro", function() return RankedFarmMacroRunning end, function()
                local now = os.clock()

                AutoPlayRankedMatch(RuntimeSettings.AutoRankedRewardRoll)

                if now - lastReward >= 30 then
                    lastReward = now
                    MacroClaimRewards()
                end

                return math.max(RuntimeSettings.RankedDelay, RuntimeSettings.RankedPostMatchDelay)
            end, 5)
        end
    end,
})

