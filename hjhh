local function HubWarn(context, err)
    local now = os.clock()
    local key = tostring(context or "Hub")
    if ErrorCooldown[key] and now - ErrorCooldown[key] < 4 then
        return
    end
    ErrorCooldown[key] = now
    warn("[BrawlRNG Hub] " .. key .. ": " .. tostring(err))
end

