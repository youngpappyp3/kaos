local function CanAffordUpgrade(upgradeId)
    if not UpgradeConfig or not UpgradeConfig.GetUpgrade or not UpgradeConfig.GetCost then
        return true
    end
    local cfg = UpgradeConfig.GetUpgrade(upgradeId)
    if not cfg then
        return false
    end
    local level = tonumber(DataCache.Upgrades and DataCache.Upgrades[upgradeId]) or 0
    if cfg.maxLevel and level >= cfg.maxLevel then
        return false
    end
    return GetCurrency(UpgradeConfig.CurrencyId or "Silver") >= (tonumber(UpgradeConfig.GetCost(upgradeId, level)) or math.huge)
end

local function ChooseUpgrade(mode)
    if not UpgradeConfig or typeof(UpgradeConfig.Upgrades) ~= "table" then
        return nil
    end
    local best
    for _, cfg in ipairs(UpgradeConfig.Upgrades) do
        if cfg and cfg.id and CanAffordUpgrade(cfg.id) then
            local level = tonumber(DataCache.Upgrades and DataCache.Upgrades[cfg.id]) or 0
            local cost = tonumber(UpgradeConfig.GetCost and UpgradeConfig.GetCost(cfg.id, level)) or 1
            local value = tonumber(cfg.bonusPerLevel) or 1
            local score = value / math.max(cost, 1)
            if mode == "Cheapest" then
                score = -cost
            elseif mode == "Combat First" then
                score = (cfg.category == "Combat" and 1000000 or 0) + score
            elseif mode == "Farm First" then
                score = ((cfg.category == "Mining" or cfg.category == "Harvesting" or cfg.category == "Logging") and 1000000 or 0) + score
            end
            if not best or score > best.score then
                best = { id = cfg.id, score = score }
            end
        end
    end
    return best and best.id or nil
end

