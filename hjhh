        "BossVault", "WildZone", "SurvivalPit", "StarVault",
    },
    CurrentOption = { "TrainingYard" },
    MultipleOptions = false,
    Flag    = "BattleMapChoice",
    Callback = function(v)
        BattleMapChoice = v[1] or v
    end,
})

local BattleDelay = 5
BattleTab:CreateInput({
    Name                = "Battle Loop Delay (seconds)",
    PlaceholderText     = "Default: 5",
    RemoveTextAfterFocusLost = false,
    Callback            = function(v)
        BattleDelay = tonumber(v) or 5
    end,
})

local AutoBattle = false
BattleTab:CreateToggle({
    Name         = "Auto Battle Loop",
    CurrentValue = false,
    Flag         = "AutoBattle",
    Callback     = function(v)
        AutoBattle = v
        if AutoBattle then
            StartManagedLoop("AutoBattle", function() return AutoBattle end, function()
                -- 1. Check current battle state
                local stateOk, state = pcall(function()
                    return GetBattleState:InvokeServer()
                end)

                if stateOk and typeof(state) == "table" then
                    -- If there's a completed result, collect it
                    if typeof(state.completedResult) == "table" then
                        pcall(function()
                            AcknowledgeBattleResult:InvokeServer({ deferBoxRewards = true })
                        end)
                        return 1
                    end

                    -- If a battle is active, wait for it
                    if typeof(state.activeBattle) == "table" then
                        return 3
                    end
                end

                -- 2. Request battle maps
                local mapsOk, mapsResult = pcall(function()
                    return RequestBattleMaps:InvokeServer()
                end)

                if not mapsOk or typeof(mapsResult) ~= "table" or mapsResult.ok ~= true then
                    return BattleDelay
                end

                -- 3. Get inventory for battle slots
                local invOk, inv = pcall(function()
                    return GetInventorySnapshot:InvokeServer()
                end)

                -- Build simple slot table (use first selected or default)
                local slots = { "shelly" }
                if invOk and typeof(inv) == "table" then
                    if typeof(inv.selectedBattleSlots) == "table" then
                        slots = inv.selectedBattleSlots
                    end
                end

                -- 4. Start battle on chosen map
                task.wait(0.3)
                pcall(function()
                    StartBattle:InvokeServer(BattleMapChoice, slots)
                end)

                return BattleDelay
            end, 3)
        end
    end,
})

