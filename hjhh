    "omnipotato_blessing",
    "transcendent_harvest",
    "galactic_harvest"
}
local ProgressionSellDelay = 20
local ProgressionAscensionDelay = 60
local ProgressionLastSellAt = 0
local ProgressionLastAscensionAt = 0
local ProgressionMacroToggle = MacroTab:CreateToggle({
    Name = "Progression Macro V1",
    CurrentValue = false,
    Flag = "ProgressionMacroV1",
    Callback = function(Value)
        progressionmacro = Value

        if progressionmacro then
            ProgressionLastSellAt = os.clock()
            ProgressionLastAscensionAt = os.clock()
            StartManagedLoop("ProgressionMacroV1", function()
                return progressionmacro
            end, function()
                for _, upgrade in ipairs(AutoUpgradeOrder) do
                    if not progressionmacro then
                        break
                    end

                    PurchaseClickUpgrade:FireServer(upgrade)
                    task.wait(0.15)
                end

                for _, upgrade in ipairs(ProgressionCoreUpgradeOrder) do
                    if not progressionmacro then
                        break
                    end

                    PurchaseClickUpgrade:FireServer(upgrade)
                    task.wait(0.3)
                end

                local now = os.clock()
                if now - ProgressionLastSellAt >= ProgressionSellDelay then
                    SellCurrentPotatoes()
                    SellCurrentGoldenPotatoes()
                    PerformPrestige:FireServer()
                    ProgressionLastSellAt = now

                    if now - ProgressionLastAscensionAt >= ProgressionAscensionDelay then
                        for _, ascension in ipairs(ProgressionAscensionOrder) do
                            if not progressionmacro then
                                break
                            end

                            PerformAscension:FireServer(ascension)
                            task.wait(0.25)
                        end

                        ProgressionLastAscensionAt = now
                    end

                    return 1
                end

                return 0.5
            end, 1)
        end
    end,
})

