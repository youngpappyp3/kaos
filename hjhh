-- ==================== SEPARATE LOOPS (THE FIX) ====================

-- Auto Tap Loop
task.spawn(function()
    while true do
        if autoTap and TapsRemote then
            local success, err = pcall(function()
                TapsRemote:FireServer()
            end)
            if not success then
                warn("[Auto Tap] Error: " .. tostring(err))
            end
        end
        task.wait(tapDelay)
    end
end)

-- Auto Rebirth Loop
task.spawn(function()
    while true do
        if autoRebirth and RebirthRemote then
            local success, err = pcall(function()
                RebirthRemote:FireServer(1)
            end)
            if not success then
                warn("[Auto Rebirth] Error: " .. tostring(err))
            end
        end
        task.wait(rebirthDelay)
    end
end)

-- Auto Hatch Loop
task.spawn(function()
    while true do
        if autoHatch and HatchRemote then
            local success, err = pcall(function()
                HatchRemote:FireServer(selectedEgg, hatchAmount)
            end)
            if not success then
                warn("[Auto Hatch] Error: " .. tostring(err))
            end
        end
        task.wait(hatchDelay)
    end
end)

-- Auto Equip Loop
task.spawn(function()
    while true do
        if autoEquip and EquipRemote then
            local success, err = pcall(function()
