BattleTab:CreateSection("Auto Open Boxes")

-- Box rewards (StarrDrops, ChaosDrops, RankedDrops, etc.) are granted by the server
-- when a completed battle result is acknowledged with deferBoxRewards = false.
-- When AutoBattle is ON this is already handled automatically inside the battle loop.
-- Enable this toggle to auto-open boxes even when AutoBattle is OFF.

-- Try to open any pending deferred battle rewards (Starr Drops, Chaos Drops)
-- The server gives a token string in the inventory snapshot under pendingDeferredBattleRewards
local function OpenPendingDeferredRewards()
    if not OpenDeferredBattleReward then return false end
    local inv
    local ok, snapshot = SafeInvoke(GetInventorySnapshot)
    if ok and typeof(snapshot) == "table" then
        inv = snapshot
        InventorySnapshotCache = snapshot
        InventorySnapshotCacheTime = os.clock()
    end
    if typeof(inv) ~= "table" then return false end
    -- Check common field names the server may use for pending deferred rewards
    local pending = inv.pendingDeferredBattleRewards
        or inv.deferredBattleRewards
        or inv.pendingStarrDrops
        or inv.starrDropTokens
    if typeof(pending) == "table" then
        local opened = false
        for _, token in ipairs(pending) do
            if typeof(token) == "string" and token ~= "" then
                SafeInvoke(OpenDeferredBattleReward, token)
                opened = true
                task.wait(0.3)
            elseif typeof(token) == "table" then
                local t = token.token or token.id or token.rewardId
                if typeof(t) == "string" and t ~= "" then
                    SafeInvoke(OpenDeferredBattleReward, t)
                    opened = true
                    task.wait(0.3)
                end
            end
        end
        if opened then
            InvalidateInventorySnapshot()
            return true
        end
    end
    -- Also try known StarrDrop/ChaosDrop box IDs from inventory counts
    if typeof(inv.boxes) == "table" or typeof(inv.boxCounts) == "table" then
        local boxes = inv.boxes or inv.boxCounts
        local specialIds = {}
        if BattleConfig and BattleConfig.StarrDropBoxId then specialIds[BattleConfig.StarrDropBoxId] = true end
        if BattleConfig and BattleConfig.ChaosDropBoxId then specialIds[BattleConfig.ChaosDropBoxId] = true end
        for boxId, count in pairs(boxes) do
            if specialIds[boxId] and (tonumber(count) or 0) > 0 and OpenBox then
                for _ = 1, math.min(tonumber(count) or 1, 10) do
                    SafeInvoke(OpenBox, boxId)
                    task.wait(0.2)
                end
                InvalidateInventorySnapshot()
            end
        end
    end
    return false
end

local function OpenAllPendingBoxes()
    -- 1. Collect from battle result
    local stateOk, state = SafeInvoke(GetBattleState)
    if stateOk and typeof(state) == "table" and typeof(state.completedResult) == "table" then
        SetBattleResult(state.completedResult)
        SetBattleStatus("Opening boxes from battle result")
        SafeInvoke(AcknowledgeBattleResult, { deferBoxRewards = false })
        InvalidateInventorySnapshot()
        task.wait(0.3)
    end
    -- 2. Open deferred star/chaos drops
    OpenPendingDeferredRewards()
    -- 3. Open any held boxes from inventory via OpenBox remote
    if OpenBox then
        local inv
        local ok, snapshot = SafeInvoke(GetInventorySnapshot)
        if ok and typeof(snapshot) == "table" then
            inv = snapshot
        end
        local boxCounts = (typeof(inv) == "table" and (inv.boxes or inv.boxCounts)) or {}
        for _, boxId in ipairs(KnownBoxIds) do
            local count = tonumber(boxCounts[boxId]) or 0
            if count > 0 then
                for _ = 1, math.min(count, 20) do
                    SafeInvoke(OpenBox, boxId)
                    task.wait(0.15)
                end
                InvalidateInventorySnapshot()
            end
        end
    end
    return true
end

