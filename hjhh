local function HubWarn(context, err)
    local now = os.clock()
    local key = tostring(context or "Hub")
    if ErrorCooldown[key] and now - ErrorCooldown[key] < 4 then
        return
    end
    ErrorCooldown[key] = now
    warn("[PetsAdventure Hub] " .. key .. ": " .. tostring(err))
end

local function HubDebug(context, message)
    warn("[PetsAdventure Hub] " .. tostring(context or "Debug") .. ": " .. tostring(message or ""))
end

