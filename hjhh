-- ==================== CACHE REMOTES ONCE ====================
local TapsRemote, RebirthRemote, HatchRemote, EquipRemote

local function cacheRemotes()
    local success, err = pcall(function()
        local KnitServices = ReplicatedStorage
            :FindFirstChild("Packages")
            and ReplicatedStorage.Packages
            :FindFirstChild("_Index")
            and ReplicatedStorage.Packages._Index
            :FindFirstChild("sleitnick_knit@1.7.0")
            and ReplicatedStorage.Packages._Index["sleitnick_knit@1.7.0"]
            :FindFirstChild("knit")
            and ReplicatedStorage.Packages._Index["sleitnick_knit@1.7.0"].knit
            :FindFirstChild("Services")

        if not KnitServices then
            KnitServices = ReplicatedStorage.Packages._Index["sleitnick_knit@1.7.0"].knit.Services
        else
            KnitServices = ReplicatedStorage.Packages._Index["sleitnick_knit@1.7.0"].knit.Services
        end

        -- Tap
        if KnitServices:FindFirstChild("TapsService") then
            TapsRemote = KnitServices.TapsService.RE.Taps
        end

        -- Rebirth
        if KnitServices:FindFirstChild("RebirthsService") then
            RebirthRemote = KnitServices.RebirthsService.RE.Rebirth
        end

        -- Hatch
        if KnitServices:FindFirstChild("EggsService") then
            HatchRemote = KnitServices.EggsService.RE.HatchEggs
        end

        -- Equip Best
        if KnitServices:FindFirstChild("PetsService") then
            EquipRemote = KnitServices.PetsService.RE.EquipBest
        end
    end)

    if not success then
        warn("[Arrayfield Hub] Failed to cache remotes: " .. tostring(err))
        return false
    end
    return true
end

-- Try caching remotes with retry
task.spawn(function()
    for attempt = 1, 10 do
        if cacheRemotes() then
            local found = {}
            if TapsRemote then table.insert(found, "Taps") end
            if RebirthRemote then table.insert(found, "Rebirth") end
            if HatchRemote then table.insert(found, "Hatch") end
            if EquipRemote then table.insert(found, "Equip") end

            print("[Arrayfield Hub] Remotes cached: " .. table.concat(found, ", "))
            Rayfield:Notify({
                Title = "Remotes Found",
                Content = "Loaded: " .. table.concat(found, ", "),
                Duration = 4,
            })
            return
        end
        warn("[Arrayfield Hub] Remote cache attempt " .. attempt .. "/10 failed, retrying...")
        task.wait(2)
    end
    Rayfield:Notify({
        Title = "Warning",
        Content = "Some remotes not found. Features may not work.",
        Duration = 6,
    })
end)

