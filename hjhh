if old then
    old:Destroy()
end

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local VirtualUser = game:GetService("VirtualUser")
local player = Players.LocalPlayer

local ClickFish = ReplicatedStorage:WaitForChild("ClickFish", 9e9)
local BuyUpgrade = ReplicatedStorage:WaitForChild("BuyUpgrade", 9e9)
local SellFish = ReplicatedStorage:WaitForChild("SellFish", 9e9)

