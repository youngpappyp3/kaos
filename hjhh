local function StartManagedLoop(name, isRunning, tickFn, errDelay)
    if ActiveLoops[name] then return end
    ActiveLoops[name] = true
    task.spawn(function()
        while isRunning() do
            local ok, waitTime = pcall(tickFn)
            if ok then
                if type(waitTime) == "number" and waitTime > 0 then
                    task.wait(waitTime)
                end
            else
                task.wait(errDelay or 1)
            end
        end
        ActiveLoops[name] = nil
    end)
end

local function SafeInvoke(remote, ...)
    if not remote then
        return false, nil
    end

    if remote:IsA("RemoteFunction") then
        return pcall(function(...)
            return remote:InvokeServer(...)
        end, ...)
    end

    if remote:IsA("RemoteEvent") then
        return pcall(function(...)
            remote:FireServer(...)
            return true
        end, ...)
    end

    return false, nil
end

local function SafeFire(remote, ...)
    if not remote then
        return false
    end

    if remote:IsA("RemoteEvent") then
        local ok = pcall(function(...)
            remote:FireServer(...)
        end, ...)
        return ok
    end

    if remote:IsA("RemoteFunction") then
        local ok = pcall(function(...)
            remote:InvokeServer(...)
        end, ...)
        return ok
    end

    return false
end

