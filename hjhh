local MacroSection = MacroTab:CreateSection("Full Progression Macro")
local MacroLabel   = MacroTab:CreateLabel("Fish → Upgrade → Sell → Prestige")

--[[
   MACRO ORDER EXPLAINED:
   1. FISH (x50 clicks)  – Build up fish inventory fast
   2. UPGRADE (1–11)     – Spend currency on all upgrades while we have it
   3. SELL (100)          – Sell fish to bank the profits
   4. REPEAT steps 1–3 for a set number of cycles
   5. PRESTIGE            – After enough cycles, prestige to reset & multiply
   6. Loop forever

   This is optimal because:
   - You want to farm fish BEFORE upgrading (upgrades cost currency from sells)
   - Upgrades boost your fish value, so buy them before the next sell
   - Sell AFTER upgrading so each sell is worth more
   - Prestige only after several sell cycles so you maximize gains per prestige
]]

local MacroCyclesBeforePrestige = 5  -- how many fish/upgrade/sell cycles before prestige
local MacroFishClicks = 50           -- fish clicks per cycle
local MacroRunning = false

local MacroCyclesInput = MacroTab:CreateInput({
   Name = "Cycles Before Prestige",
   PlaceholderText = "Default: 5",
   RemoveTextAfterFocusLost = false,
   Callback = function(Value)
      MacroCyclesBeforePrestige = tonumber(Value) or 5
   end,
})

local MacroFishInput = MacroTab:CreateInput({
   Name = "Fish Clicks Per Cycle",
   PlaceholderText = "Default: 50",
   RemoveTextAfterFocusLost = false,
   Callback = function(Value)
      MacroFishClicks = tonumber(Value) or 50
   end,
})

local MacroToggle = MacroTab:CreateToggle({
   Name = "Progression Macro",
   CurrentValue = false,
   Flag = "ProgressionMacroToggle",
   Callback = function(Value)
      MacroRunning = Value

      if MacroRunning then
         StartManagedLoop("ProgressionMacro", function()
            return MacroRunning
         end, function()
            for cycle = 1, MacroCyclesBeforePrestige do
               if not MacroRunning then break end

               -- Step 1: Fish rapidly
               for i = 1, MacroFishClicks do
                  if not MacroRunning then break end
                  ClickFish:FireServer()
                  task.wait(0.1)
               end

               -- Step 2: Buy all upgrades 1–11
               for upgradeId = 1, 11 do
                  if not MacroRunning then break end
                  BuyUpgrade:FireServer(upgradeId)
                  task.wait(0.15)
               end

               -- Step 3: Sell fish
               SellFish:FireServer(100)
               task.wait(0.5)
            end

            -- Step 4: Prestige after all cycles
            if MacroRunning then
               DoPrestige:FireServer()
               task.wait(2)
            end

            return 1
         end, 1)
      end
   end,
})

