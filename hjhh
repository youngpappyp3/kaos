local function CanRebirth()
    if not RebirthConfig then
        return true
    end
    local rebirthCount = tonumber(DataCache.RebirthCount) or 0
    if RebirthConfig.MaxRebirths and rebirthCount >= RebirthConfig.MaxRebirths then
        return false
    end
    local tier = RebirthConfig.GetTier and RebirthConfig.GetTier(rebirthCount + 1)
    if typeof(tier) ~= "table" then
        return false
    end
    if typeof(tier.currencies) == "table" then
        for _, req in ipairs(tier.currencies) do
            if GetCurrency(req.currencyId) < (tonumber(req.amount) or 0) then
                return false
            end
        end
    end
    if typeof(tier.items) == "table" then
        for _, req in ipairs(tier.items) do
            if GetInventoryItemCount(req.itemId) < (tonumber(req.amount) or 0) then
                return false
            end
        end
    end
    if typeof(tier.pets) == "table" then
        for _, req in ipairs(tier.pets) do
            local met = false
            for _, pet in pairs(PetDataCache.Owned or {}) do
                if typeof(pet) == "table" and pet.petId == req.petId and (req.mutation == nil or pet.mutation == req.mutation) and GetPetLevel(pet) >= (tonumber(req.level) or 0) then
                    met = true
                    break
                end
            end
            if not met then
                return false
            end
        end
    end
    return true
end

local function ClaimDailyAvailable()
    local claimed = DailyCache.claimed or {}
    local totalPlaytime = tonumber(DailyCache.totalPlaytime) or 0
    local maxTier = DailyRewardsConfig and DailyRewardsConfig.GetTierCount and DailyRewardsConfig.GetTierCount() or 12
    local claimedCount = 0
    for i = 1, maxTier do
        if claimed[tostring(i)] then
            claimedCount += 1
        else
            local tier = DailyRewardsConfig and DailyRewardsConfig.GetTier and DailyRewardsConfig.GetTier(i)
            if not tier or totalPlaytime >= (tonumber(tier.timeRequired) or 0) then
                SafeFire("ClaimDailyReward", i)
                task.wait(0.1)
            end
        end
    end
    return claimedCount
end

