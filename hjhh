local function StartManagedLoop(name, isRunning, tickFn, errDelay)
    if ActiveLoops[name] then return end
    ActiveLoops[name] = true
    task.spawn(function()
        while isRunning() do
            local ok, waitTime = pcall(tickFn)
            if ok then
                if type(waitTime) == "number" and waitTime > 0 then
                    task.wait(math.max(waitTime, MIN_LOOP_WAIT))
                else
                    task.wait(MIN_LOOP_WAIT)
                end
            else
                task.wait(math.max(tonumber(errDelay) or 1, MIN_LOOP_WAIT))
            end
        end
        ActiveLoops[name] = nil
    end)
end

local function SetRayfieldLabel(label, text)
    if not label then
        return
    end

    text = tostring(text or "")
    if LabelTextCache[label] == text then
        return
    end

    local ok = false
    if label.Set then
        ok = pcall(function()
            label:Set(text)
        end)
    elseif label.Update then
        ok = pcall(function()
            label:Update(text)
        end)
    end

    if ok then
        LabelTextCache[label] = text
    end
end

