                -- 4. Roll dice
                if MacroDiceEnabled and now - MacroLastDice >= 0.5 then
                    MacroLastDice = now
                    MacroRollAvailableDice()
                end

                -- 5. Battle cycle
                if MacroBattleEnabled and now - MacroLastBattle >= 3 then
                    MacroLastBattle = now
                    RequestAndStartSmartBattle(MacroBattleChoiceMode, MacroMapChoice, BattleAutoEquipBest)
                    -- Open boxes from completed battle result immediately
                    MacroOpenBoxes()
                end

                -- 6. Claim rewards
                if now - MacroLastReward >= 30 then
                    MacroLastReward = now
                    MacroClaimRewards()
                end

                return 0.1
            end, 1)
        end
    end,
})

