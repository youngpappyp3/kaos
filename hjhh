-- Shared managed loop helper
-- ─────────────────────────────────────────────
local ActiveLoops = {}

local function StartManagedLoop(loopName, isRunning, tickFn, errorDelay)
   if ActiveLoops[loopName] then
      Log("Loop", loopName .. " already running, skipping duplicate start")
      return
   end

   ActiveLoops[loopName] = true
   Log("Loop", loopName .. " started")

   task.spawn(function()
      while isRunning() do
         local ok, result = pcall(tickFn)
         if ok then
            if type(result) == "number" and result > 0 then
               task.wait(result)
            end
         else
            -- result is the error message when pcall fails
            Log("Loop:ERROR", loopName .. " error: " .. tostring(result))
            task.wait(errorDelay or 1)
         end
      end

      ActiveLoops[loopName] = nil
      Log("Loop", loopName .. " stopped")
   end)
end

-- ─────────────────────────────────────────────
-- Minigame overlay finder
-- ─────────────────────────────────────────────
local function FindMinigameOverlay()
   local playerGui = player:FindFirstChildOfClass("PlayerGui")
   if not playerGui then
      return nil
   end

   for _, guiObject in ipairs(playerGui:GetDescendants()) do
      if guiObject.Name == "MinigameOverlay"
         and guiObject:IsA("GuiObject")
         and guiObject.Visible then
         return guiObject
      end
   end

   return nil
end

