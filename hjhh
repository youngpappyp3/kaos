-- Arrayfield Hub - Tap + Hatch + Anti-AFK (Minimal & Clean)

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local VirtualUser = game:GetService("VirtualUser")
local LocalPlayer = Players.LocalPlayer

local Rayfield = loadstring(game:HttpGet('https://raw.githubusercontent.com/UI-Interface/CustomFIeld/main/RayField.lua'))()

local Window = Rayfield:CreateWindow({
    Name = "Arrayfield Hub",
    LoadingTitle = "Tap + Hatch",
    LoadingSubtitle = "by Arrays",
    KeySystem = false,
})

-- Tabs
local MainTab = Window:CreateTab("Main", 4483362458)
local SettingsTab = Window:CreateTab("Settings")

-- Variables
local autoTap = false
local autoHatch = false
local selectedEgg = "Basic"
local hatchAmount = 1
local antiAFKEnabled = false
local antiAFKConnection = nil

-- ==================== MAIN TAB ====================
MainTab:CreateSection("Auto Features")

MainTab:CreateToggle({
    Name = "Auto Tap (0.1s)",
    CurrentValue = false,
    Callback = function(Value)
        autoTap = Value
        Rayfield:Notify("Auto Tap", Value and "ON - Spamming every 0.1s" or "OFF", 3)
    end,
})

MainTab:CreateToggle({
    Name = "Auto Hatch",
    CurrentValue = false,
    Callback = function(Value)
        autoHatch = Value
        Rayfield:Notify("Auto Hatch", Value and "ON" or "OFF", 3)
    end,
})

-- Egg Dropdown (REAL names from your game)
MainTab:CreateDropdown({
    Name = "Select Egg",
    Options = {"Basic", "Beach", "Hype", "Ice", "Lava", "Mountain", "Mushroom", "Question", "Release", "Sakura"},
    CurrentOption = {"Basic"},
    MultipleOptions = false,
    Callback = function(Option)
        selectedEgg = Option[1]
        print("Egg changed to: " .. selectedEgg)
        Rayfield:Notify("Egg Selected", selectedEgg, 2)
    end,
})

MainTab:CreateSlider({
    Name = "Hatch Amount",
    Range = {1, 50},
    Increment = 1,
    Suffix = " eggs",
    CurrentValue = 1,
    Callback = function(Value)
        hatchAmount = Value
        print("Hatch amount set to: " .. hatchAmount)
    end,
})

-- ==================== SETTINGS TAB ====================
SettingsTab:CreateSection("Anti-AFK")

SettingsTab:CreateToggle({
    Name = "Enable Anti-AFK",
    CurrentValue = false,
    Callback = function(Value)
        antiAFKEnabled = Value
        if Value then
            if antiAFKConnection then antiAFKConnection:Disconnect() end
            antiAFKConnection = LocalPlayer.Idled:Connect(function()
                pcall(function()
                    VirtualUser:Button2Down(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
                    task.wait(1)
                    VirtualUser:Button2Up(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
                end)
            end)
            Rayfield:Notify("Anti-AFK", "Enabled - You won't get kicked!", 4)
        else
            if antiAFKConnection then
                antiAFKConnection:Disconnect()
                antiAFKConnection = nil
            end
            Rayfield:Notify("Anti-AFK", "Disabled", 3)
        end
    end,
})

-- ==================== LOOPS ====================

-- Auto Tap (your working 0.1s loop)
task.spawn(function()
    while true do
        if autoTap then
            print("🔨 FIRING TAP...")
            local args = {}
            pcall(function()
                ReplicatedStorage:WaitForChild("Packages", 9e9):WaitForChild("_Index", 9e9):WaitForChild("sleitnick_knit@1.7.0", 9e9):WaitForChild("knit", 9e9):WaitForChild("Services", 9e9):WaitForChild("TapsService", 9e9):WaitForChild("RE", 9e9):WaitForChild("Taps", 9e9):FireServer(unpack(args))
            end)
        end
        task.wait(0.1)
    end
end)

-- Auto Hatch (your exact remote + real egg names)
task.spawn(function()
    while true do
        if autoHatch then
            print("🥚 FIRING HATCH - " .. selectedEgg .. " x" .. hatchAmount)
            local args = { [1] = selectedEgg, [2] = hatchAmount }
            pcall(function()
                ReplicatedStorage:WaitForChild("Packages", 9e9):WaitForChild("_Index", 9e9):WaitForChild("sleitnick_knit@1.7.0", 9e9):WaitForChild("knit", 9e9):WaitForChild("Services", 9e9):WaitForChild("EggsService", 9e9):WaitForChild("RE", 9e9):WaitForChild("HatchEggs", 9e9):FireServer(unpack(args))
            end)
        end
        task.wait(1.8) -- safe delay (change if too fast/slow)
    end
end)

print("✅ Hub Loaded - Toggle Auto Tap & Auto Hatch!")
Rayfield:Notify("Ready!", "Main tab = Tap & Hatch | Settings = Anti-AFK", 6)
