MacroTab:CreateSection("BrawlMax Macro")
MacroTab:CreateLabel("Click -> Upgrades -> Rebirth -> Battle -> Dice")

local MacroRunning       = false
local MacroRebirthDelay  = 60
local MacroLastRebirth   = 0
local MacroDiceEnabled   = true
local MacroBattleEnabled = true
local MacroMapChoice     = "TrainingYard"
local MacroBattleChoiceMode = "Best Win Chance"

MacroTab:CreateInput({
    Name                = "Macro Rebirth Interval (s)",
    PlaceholderText     = "Default: 60",
    RemoveTextAfterFocusLost = false,
    Callback            = function(v) MacroRebirthDelay = tonumber(v) or 60 end,
})

MacroTab:CreateToggle({
    Name         = "Include Dice Rolls",
    CurrentValue = true,
    Flag         = "MacroDice",
    Callback     = function(v) MacroDiceEnabled = v end,
})

MacroTab:CreateToggle({
    Name         = "Include Auto Battle",
    CurrentValue = true,
    Flag         = "MacroBattle",
    Callback     = function(v) MacroBattleEnabled = v end,
})

MacroTab:CreateDropdown({
    Name    = "Macro Battle Map",
    Options = {
        "TrainingYard", "CoinCave", "GemTunnel", "PowerPit",
        "ScrapYard", "TrophyTrail", "HeistRoom", "AmbushValley",
        "BossVault", "WildZone", "SurvivalPit", "StarVault",
    },
    CurrentOption = { "TrainingYard" },
    MultipleOptions = false,
    Flag    = "MacroMapChoice",
    Callback = function(v) MacroMapChoice = v[1] or v end,
})

MacroTab:CreateDropdown({
    Name    = "Macro Battle Choice Mode",
    Options = { "Best Win Chance", "Best Reward", "Manual Dropdown" },
    CurrentOption = { "Best Win Chance" },
    MultipleOptions = false,
    Flag    = "MacroBattleChoiceMode",
    Callback = function(v) MacroBattleChoiceMode = v[1] or v end,
})

MacroTab:CreateToggle({
    Name         = "BrawlMax Macro",
    CurrentValue = false,
    Flag         = "BrawlMaxMacro",
    Callback     = function(v)
        MacroRunning     = v
        MacroLastRebirth = os.clock()

        if MacroRunning then
            StartManagedLoop("BrawlMaxMacro", function() return MacroRunning end, function()
                local now = os.clock()

                -- 1. Buy all upgrades (max)
                local snapshot = GetUpgradeSnapshot()
                for _, entry in ipairs(UpgradeList) do
                    if not MacroRunning then break end
                    SmartPurchaseUpgrade(entry[1], "max", snapshot)
                    task.wait(0.05)
                end

                -- 2. Tap
                SafeFire(ClickerTap)
                task.wait(0.05)

                -- 3. Rebirth on timer
                if now - MacroLastRebirth >= MacroRebirthDelay then
                    SmartPurchaseRebirth()
                    MacroLastRebirth = now
                    task.wait(0.3)
                end

                -- 4. Roll dice
                if MacroDiceEnabled then
                    if GetDiceCount("regular") > 0 then
                        SmartRollDice("regular")
                        task.wait(0.1)
                    end
                    if GetDiceCount("golden") > 0 then
                        SmartRollDice("golden")
                        task.wait(0.1)
                    end
                    if GetDiceCount("mythical") > 0 then
                        SmartRollDice("mythical")
                        task.wait(0.1)
                    end
                end

                -- 5. Battle cycle
                if MacroBattleEnabled then
                    RequestAndStartSmartBattle(MacroBattleChoiceMode, MacroMapChoice)
                end

                -- 6. Claim rewards
                pcall(function() ClaimDailyReward:InvokeServer() end)
                ClaimAllKnownAchievements(0.02)
                pcall(function() ClaimTrophyRoadRankUpReward:InvokeServer() end)

                return 0.1
            end, 1)
        end
    end,
})

