-- ── Managed loop helper ───────────────────────────────────────
local ActiveLoops = {}

local function StartManagedLoop(name, isRunning, tickFn, errDelay)
    if ActiveLoops[name] then return end
    ActiveLoops[name] = true
    task.spawn(function()
        while isRunning() do
            local ok, wait = pcall(tickFn)
            if ok then
                if type(wait) == "number" and wait > 0 then
                    task.wait(wait)
                end
            else
                task.wait(errDelay or 1)
            end
        end
        ActiveLoops[name] = nil
    end)
end

