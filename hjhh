local function GetBrawlerBaseScore(brawlerId, state)
    local level = tonumber(state and state.level) or 1
    local trophies = tonumber(state and state.trophies) or 0
    local brawler = BrawlerLibrary and BrawlerLibrary.ById and BrawlerLibrary.ById[brawlerId] or nil
    local rarityScore = 0

    if brawler and brawler.rarity then
        local rarity = tostring(brawler.rarity)
        rarityScore = BrawlerRarityScore[rarity] or 0
    end

    return level * 100000 + trophies * 10 + rarityScore
end

local function GetUnlockedBrawlerCandidates(inventory, mapId)
    local candidates = {}
    if typeof(inventory) ~= "table" or typeof(inventory.byId) ~= "table" then
        return candidates
    end

    for brawlerId, state in pairs(inventory.byId) do
        if typeof(brawlerId) == "string" and typeof(state) == "table" and state.unlocked == true then
            candidates[#candidates + 1] = {
                id = brawlerId,
                score = GetBrawlerBaseScore(brawlerId, state),
                classKey = GetBrawlerClassKey(brawlerId),
            }
        end
    end

    table.sort(candidates, function(a, b)
        return a.score > b.score
    end)

    local trimmed = {}
    local included = {}
    local perClassCount = {}

    local function include(candidate)
        if not candidate or included[candidate.id] then
            return
        end
        included[candidate.id] = true
        trimmed[#trimmed + 1] = candidate
    end

    for i = 1, math.min(#candidates, 14) do
        include(candidates[i])
    end

    if not mapId then
        return trimmed
    end

    local recommendedClasses = GetMapRecommendedClasses(mapId)
    local recommendedSet = {}
    for _, classKey in ipairs(recommendedClasses) do
        if typeof(classKey) == "string" then
            recommendedSet[classKey] = true
        end
    end

    local selectedSet = {}
    if typeof(inventory.selectedBattleSlots) == "table" then
        for _, brawlerId in ipairs(inventory.selectedBattleSlots) do
            if typeof(brawlerId) == "string" then
                selectedSet[brawlerId] = true
            end
        end
    end

    for _, candidate in ipairs(candidates) do
        if selectedSet[candidate.id] then
            include(candidate)
        end
        if candidate.classKey and recommendedSet[candidate.classKey] then
            local count = perClassCount[candidate.classKey] or 0
            if count < 5 then
                perClassCount[candidate.classKey] = count + 1
                include(candidate)
            end
        end
    end
    return trimmed
end

local function ScoreBattleSlots(mapId, slots, inventory)
    local preview = GetMapPreview(mapId, slots, inventory)
    if preview then
        local matchedClasses = typeof(preview.matchedRecommendedClasses) == "table" and #preview.matchedRecommendedClasses or 0
        local durationScore = math.max(0, 1000 - (tonumber(preview.durationSeconds) or 1000))
        local score = (tonumber(preview.winChance) or 0) * 1000000
            + matchedClasses * 100000
            + (tonumber(preview.trophyReward) or 0) * 10
            + durationScore
        return score, preview
    end

    local score = 0
    for _, slot in ipairs(slots) do
        if typeof(slot) == "string" and inventory and inventory.byId then
            score += GetBrawlerBaseScore(slot, inventory.byId[slot] or {})
        end
    end
    return score, nil
end

local function ChooseBestBattleSlotsForMap(mapId, inventory)
    local candidates = GetUnlockedBrawlerCandidates(inventory, mapId)
    if #candidates <= 0 then
        return { "shelly", false, false }, nil
    end

    local bestSlots = nil
    local bestScore = nil
    local bestPreview = nil

    local function consider(slots)
        local padded = { slots[1] or false, slots[2] or false, slots[3] or false }
        local score, preview = ScoreBattleSlots(mapId, padded, inventory)
        if not bestScore or score > bestScore then
            bestScore = score
            bestSlots = padded
            bestPreview = preview
        end
    end

    for i = 1, #candidates do
        consider({ candidates[i].id })
        for j = i + 1, #candidates do
            consider({ candidates[i].id, candidates[j].id })
            for k = j + 1, #candidates do
                consider({ candidates[i].id, candidates[j].id, candidates[k].id })
            end
        end
    end

    return bestSlots or { candidates[1].id, false, false }, bestPreview
end

local function ExtractMapIdsFromOffer(result)
    if typeof(result) ~= "table" then
        return {}
    end

    local battleState = typeof(result.battleState) == "table" and result.battleState or result
    local offer = typeof(battleState.pendingMapOffer) == "table" and battleState.pendingMapOffer or result.pendingMapOffer

    if typeof(offer) == "table" and typeof(offer.mapIds) == "table" then
        return offer.mapIds
    end

    if typeof(result.mapIds) == "table" then
        return result.mapIds
    end

    if typeof(result.maps) == "table" then
        local ids = {}
        for _, map in ipairs(result.maps) do
            if typeof(map) == "string" then
                ids[#ids + 1] = map
            elseif typeof(map) == "table" and typeof(map.id or map.mapId) == "string" then
                ids[#ids + 1] = map.id or map.mapId
            end
        end
        return ids
    end

    return {}
end

