local function IsBetterBattleMap(candidate, current, mode)
    if not current then
        return true
    end

    if mode == "Best Reward" then
        if candidate.trophyReward == current.trophyReward then
            if candidate.winChance == current.winChance then
                return candidate.order > current.order
            end
            return candidate.winChance > current.winChance
        end
        return candidate.trophyReward > current.trophyReward
    end

    if candidate.winChance == current.winChance then
        if candidate.trophyReward == current.trophyReward then
            return candidate.order > current.order
        end
        return candidate.trophyReward > current.trophyReward
    end
    return candidate.winChance > current.winChance
end

local function BuildBattleMapCandidate(mapId, slots, inventory)
    local map = GetMapConfig(mapId)
    local preview = GetMapPreview(mapId, slots, inventory)
    return {
        mapId = mapId,
        order = tonumber(map and map.order) or BattleMapOrder[mapId] or 0,
        trophyReward = tonumber(preview and preview.trophyReward) or tonumber(map and map.trophyReward) or 0,
        winChance = tonumber(preview and preview.winChance) or tonumber(map and map.baseWinChance) or 0,
        preview = preview,
    }
end

local function ChooseBattleMap(mapIds, slots, inventory, mode, fallbackMap)
    if mode == "Manual Dropdown" then
        return fallbackMap
    end

    local best = nil
    for _, mapId in ipairs(mapIds or {}) do
        if typeof(mapId) == "string" then
            local candidate = BuildBattleMapCandidate(mapId, slots, inventory)
            if IsBetterBattleMap(candidate, best, mode) then
                best = candidate
            end
        end
    end

    return (best and best.mapId) or fallbackMap
end

local function ChooseBattleMapAndSlots(mapIds, slots, inventory, mode, fallbackMap, autoEquipBest)
    if mode == "Manual Dropdown" then
        local manualMap = fallbackMap
        if autoEquipBest and typeof(manualMap) == "string" then
            local bestSlots = ChooseBestBattleSlotsForMap(manualMap, inventory)
            return manualMap, bestSlots
        end
        return manualMap, slots
    end

    if autoEquipBest then
        local best = nil
        local bestSlots = nil
        for _, mapId in ipairs(mapIds or {}) do
            if typeof(mapId) == "string" then
                local candidateSlots = ChooseBestBattleSlotsForMap(mapId, inventory)
                local candidate = BuildBattleMapCandidate(mapId, candidateSlots, inventory)
                if IsBetterBattleMap(candidate, best, mode) then
                    best = candidate
                    bestSlots = candidateSlots
                end
            end
        end

        if best then
            return best.mapId, bestSlots
        end
    end

    local chosenMap = ChooseBattleMap(mapIds, slots, inventory, mode, fallbackMap)
    if autoEquipBest and typeof(chosenMap) == "string" then
        return chosenMap, ChooseBestBattleSlotsForMap(chosenMap, inventory)
    end
    return chosenMap, slots
end

local function RequestAndStartSmartBattle(mode, fallbackMap)
    local existingMapIds = {}
    local stateOk, state = SafeInvoke(GetBattleState)
    if stateOk and typeof(state) == "table" then
        if typeof(state.completedResult) == "table" then
            SetBattleResult(state.completedResult)
            SetBattleStatus("Completed - collecting")
            local ackOk, ackResult = SafeInvoke(AcknowledgeBattleResult, { deferBoxRewards = true })
            task.wait(0.15)
            if ackOk and OpenAllDeferredBattleRewards then
                OpenAllDeferredBattleRewards(typeof(ackResult) == "table" and (ackResult.battleState or ackResult) or nil)
            end
            return true, 1
        end

        if typeof(state.activeBattle) == "table" then
            local mapId = tostring(state.activeBattle.mapId or "?")
            local endTime = tonumber(state.activeBattle.endTime)
            if endTime then
                SetBattleStatus("Active: " .. mapId .. " | ends " .. tostring(math.max(0, math.floor(endTime - os.time()))) .. "s")
            else
                SetBattleStatus("Active: " .. mapId)
            end
            return true, 3
        end

        existingMapIds = ExtractMapIdsFromOffer(state)
    end

    local slots, inventory = GetBattleSlots()
    local mapsOk, mapsResult = SafeInvoke(RequestBattleMaps)
    if not mapsOk or typeof(mapsResult) ~= "table" then
        return false, nil
    end

    local mapIds = ExtractMapIdsFromOffer(mapsResult)
    if #mapIds <= 0 then
        mapIds = existingMapIds
    end

    if mode ~= "Manual Dropdown" and #mapIds <= 0 then
        return false, nil
    end

    local chosenMap, plannedSlots = ChooseBattleMapAndSlots(mapIds, slots, inventory, mode, fallbackMap, true)
    if typeof(chosenMap) ~= "string" then
        SetBattleStatus("No valid map")
        return false, nil
    end
    LastBattleRoleMap = chosenMap

    local bestSlots = plannedSlots or ChooseBestBattleSlotsForMap(chosenMap, inventory)
    if typeof(bestSlots) == "table" then
        slots = bestSlots
        if SafeFire(SetSelectedBattleSlots, slots) then
            InvalidateInventorySnapshot()
        end
        task.wait(0.15)
    end

    SetBattleOffer(mapIds, chosenMap)
    SetBattleSlots(slots)
    SetBattleStatus("Starting: " .. chosenMap)
    local startOk = SafeInvoke(StartBattle, chosenMap, slots)
    if startOk then
        SetBattleStatus("Started: " .. chosenMap)
    else
        SetBattleStatus("Start failed: " .. chosenMap)
    end
    return startOk, chosenMap
end

local function RefreshBattleStatus()
    local stateOk, state = SafeInvoke(GetBattleState)
    if not stateOk or typeof(state) ~= "table" then
        SetBattleStatus("Refresh failed")
        return nil
    end

    if typeof(state.completedResult) == "table" then
        SetBattleResult(state.completedResult)
        SetBattleStatus("Completed - ready to collect")
        return state
    end

    if typeof(state.activeBattle) == "table" then
        local mapId = tostring(state.activeBattle.mapId or "?")
        local endTime = tonumber(state.activeBattle.endTime)
        if endTime then
            SetBattleStatus("Active: " .. mapId .. " | ends " .. tostring(math.max(0, math.floor(endTime - os.time()))) .. "s")
        else
            SetBattleStatus("Active: " .. mapId)
        end
        return state
    end

    SetBattleStatus("Idle")
    SetBattleOffer(ExtractMapIdsFromOffer(state), nil)
    return state
end

local function GetDeferredBattleRewardsFromState(state)
    if typeof(state) ~= "table" then
        return nil
    end
    if typeof(state.deferredBattleRewards) == "table" then
        return state.deferredBattleRewards
    end
    if typeof(state.battleState) == "table" and typeof(state.battleState.deferredBattleRewards) == "table" then
        return state.battleState.deferredBattleRewards
    end
    return nil
end

local function GetDeferredQueueCount(queue)
    local count = 0
    if typeof(queue) ~= "table" then
        return 0
    end
    for _, entry in ipairs(queue) do
        if typeof(entry) == "table" then
            count += math.max(1, math.floor(tonumber(entry.count) or 1))
        end
    end
    return count
end

local function CountDeferredBattleRewards(deferredRewards)
    local count = 0
    if typeof(deferredRewards) ~= "table" then
        return 0
    end
    for _, kind in ipairs({ "box", "drop", "angelicDemonicDrop" }) do
        count += GetDeferredQueueCount(deferredRewards[kind])
    end
    return count
end

OpenAllDeferredBattleRewards = function(state)
    local deferredRewards = GetDeferredBattleRewardsFromState(state)
    if not deferredRewards then
        local stateOk, latestState = SafeInvoke(GetBattleState)
        if stateOk then
            deferredRewards = GetDeferredBattleRewardsFromState(latestState)
        end
    end

    if CountDeferredBattleRewards(deferredRewards) <= 0 then
        return false, 0
    end

    local opened = 0
    for _, kind in ipairs({ "box", "drop", "angelicDemonicDrop" }) do
        local queue = deferredRewards[kind]
        if GetDeferredQueueCount(queue) > 0 then
            if OpenDeferredBattleRewards then
                for _ = 1, 100 do
                    local ok, result = SafeInvoke(OpenDeferredBattleRewards, kind)
                    if not ok or typeof(result) ~= "table" or result.ok ~= true then
                        break
                    end
                    opened += 1
                    if result.hasMore ~= true then
                        break
                    end
                    task.wait()
                end
            elseif OpenDeferredBattleReward then
                for _, entry in ipairs(queue) do
                    local pendingId = typeof(entry) == "table" and tostring(entry.id or "") or ""
                    local count = typeof(entry) == "table" and math.max(1, math.floor(tonumber(entry.count) or 1)) or 1
                    if pendingId ~= "" then
                        for _ = 1, count do
                            local ok, result = SafeInvoke(OpenDeferredBattleReward, pendingId)
                            if not ok or (typeof(result) == "table" and result.ok == false) then
                                break
                            end
                            opened += 1
                            task.wait()
                        end
                    end
                end
            end
        end
    end

    if opened > 0 then
        InvalidateInventorySnapshot()
        SetBattleStatus("Opened deferred battle rewards: " .. tostring(opened))
        return true, opened
    end
    return false, 0
end

local function GetPlayerNumberValue(name)
    local value = NumberValueCache[name]
    if not value or value.Parent ~= player then
        value = player:FindFirstChild(name)
        NumberValueCache[name] = value
    end

    if value and (value:IsA("NumberValue") or value:IsA("IntValue")) then
        return tonumber(value.Value) or 0
    end
    return 0
end

local function GetCoins()
    return GetPlayerNumberValue("Coins")
end

local function GetPowerPoints()
    return GetPlayerNumberValue("PowerPoints")
end

local function GetRebirthCount()
    return GetPlayerNumberValue("Rebirth")
end

local BrawlerUpgradeTemporaryBlocks = {}

local function GetBrawlerUpgradeResourceSignature()
    return tostring(GetCoins()) .. "|" .. tostring(GetPowerPoints())
end

local function ClearBrawlerUpgradeTemporaryBlock(brawlerId)
    if typeof(brawlerId) == "string" then
        BrawlerUpgradeTemporaryBlocks[brawlerId] = nil
    end
end

local function SetBrawlerUpgradeTemporaryBlock(brawlerId, reason)
    if typeof(brawlerId) ~= "string" or brawlerId == "" then
        return
    end

    BrawlerUpgradeTemporaryBlocks[brawlerId] = {
        reason = tostring(reason or "server rejected upgrade"),
        resourceSignature = GetBrawlerUpgradeResourceSignature(),
        expiresAt = os.clock() + 30,
    }
end

local function GetBrawlerUpgradeTemporaryBlockReason(brawlerId)
    local block = BrawlerUpgradeTemporaryBlocks[brawlerId]
    if typeof(block) ~= "table" then
        return nil
    end

    if os.clock() >= (tonumber(block.expiresAt) or 0) then
        BrawlerUpgradeTemporaryBlocks[brawlerId] = nil
        return nil
    end

    if block.resourceSignature ~= GetBrawlerUpgradeResourceSignature() then
        BrawlerUpgradeTemporaryBlocks[brawlerId] = nil
        return nil
    end

    return block.reason or "server rejected upgrade"
end

local function GetUpgradeSnapshot()
    local now = os.clock()
    if UpgradeSnapshotCache and now - UpgradeSnapshotCacheTime <= UPGRADE_CACHE_SECONDS then
        return UpgradeSnapshotCache
    end

    local ok, state = SafeInvoke(GetUpgradeState)
    if ok and typeof(state) == "table" then
        if UpgradesConfig and UpgradesConfig.buildSnapshot then
            local buildOk, snapshot = pcall(function()
                return UpgradesConfig.buildSnapshot(state.levels, state.groupUnlocked, {
                    Rebirth = state.rebirthCount or GetRebirthCount(),
                }, state.generator)
            end)
            if buildOk and typeof(snapshot) == "table" then
                UpgradeSnapshotCache = snapshot
                UpgradeSnapshotCacheTime = now
                return snapshot
            end
        end
        UpgradeSnapshotCache = state
        UpgradeSnapshotCacheTime = now
        return state
    end

    if UpgradesConfig and UpgradesConfig.buildSnapshot then
        local fallbackOk, snapshot = pcall(function()
            return UpgradesConfig.buildSnapshot(nil, false, {
                Rebirth = GetRebirthCount(),
            })
        end)
        if fallbackOk and typeof(snapshot) == "table" then
            UpgradeSnapshotCache = snapshot
            UpgradeSnapshotCacheTime = now
            return snapshot
        end
    end

    local fallback = {
        levels = {
            ClickPower = 0,
            CoinGenerator = 0,
            AutoClicker = 1,
        },
        rebirthCount = GetRebirthCount(),
    }
    UpgradeSnapshotCache = fallback
    UpgradeSnapshotCacheTime = now
    return fallback
end

local function GetUpgradeLevel(snapshot, upgradeId)
    if typeof(snapshot) == "table" and typeof(snapshot.levels) == "table" then
        return tonumber(snapshot.levels[upgradeId]) or 0
    end
    return 0
end

local function CanAffordUpgrade(upgradeId, buyMode, snapshot)
    if not UpgradesConfig then
        return true
    end

    snapshot = snapshot or GetUpgradeSnapshot()
    local rebirthCount = tonumber(snapshot.rebirthCount) or GetRebirthCount()
    local level = GetUpgradeLevel(snapshot, upgradeId)
    local coins = GetCoins()

    if UpgradesConfig.getMaxLevel and level >= UpgradesConfig.getMaxLevel(upgradeId, rebirthCount) then
        return false
    end

    if buyMode == "max" and UpgradesConfig.getAffordableCount then
        local ok, count = pcall(function()
            return UpgradesConfig.getAffordableCount(upgradeId, level, coins, rebirthCount)
        end)
        count = tonumber(count) or 0
        return ok and count > 0
    end

    if UpgradesConfig.getPriceForLevel then
        local ok, price = pcall(function()
            return UpgradesConfig.getPriceForLevel(upgradeId, level, rebirthCount)
        end)
        price = tonumber(price)
        return ok and price ~= nil and coins >= price
    end

    return true
end

local function SmartPurchaseUpgrade(upgradeId, buyMode, snapshot)
    if CanAffordUpgrade(upgradeId, buyMode, snapshot) then
        local ok, result = SafeInvoke(PurchaseUpgrade, upgradeId, buyMode)
        if ok then
            InvalidateUpgradeSnapshot()
        end
        return ok, result
    end
    return false, nil
end

local function GetUpgradeCandidate(upgradeId, snapshot)
    if not UpgradesConfig or not UpgradesConfig.getPriceForLevel then
        return nil
    end

    local rebirthCount = tonumber(snapshot.rebirthCount) or GetRebirthCount()
    local level = GetUpgradeLevel(snapshot, upgradeId)
    local okPrice, price = pcall(function()
        return UpgradesConfig.getPriceForLevel(upgradeId, level, rebirthCount)
    end)
    price = okPrice and tonumber(price) or nil
    if not price or price > GetCoins() then
        return nil
    end

    local valueGain = 1
    if UpgradesConfig.getValueAtLevel then
        local okCurrent, currentValue = pcall(function()
            return UpgradesConfig.getValueAtLevel(upgradeId, level)
        end)
        local okNext, nextValue = pcall(function()
            return UpgradesConfig.getValueAtLevel(upgradeId, level + 1)
        end)
        if okCurrent and okNext then
            valueGain = math.max(1, (tonumber(nextValue) or 0) - (tonumber(currentValue) or 0))
        end
    end

    return {
        id = upgradeId,
        price = price,
        value = valueGain / math.max(price, 1),
    }
end

local function ChooseSmartUpgrade(mode, snapshot)
    if mode == "Fixed Order" then
        for _, entry in ipairs(UpgradeList) do
            if CanAffordUpgrade(entry[1], "single", snapshot) then
                return entry[1]
            end
        end
        return nil
    end

    local best = nil
    for _, entry in ipairs(UpgradeList) do
        local candidate = GetUpgradeCandidate(entry[1], snapshot)
        if candidate then
            if not best then
                best = candidate
            elseif mode == "Cheapest" and candidate.price < best.price then
                best = candidate
            elseif mode == "Best Value" and candidate.value > best.value then
                best = candidate
            end
        end
    end

    return best and best.id or nil
end

local function CanRebirth()
    if not UpgradesConfig or not UpgradesConfig.getRebirthCost then
        return true
    end

    local ok, cost = pcall(function()
        return UpgradesConfig.getRebirthCost(GetRebirthCount())
    end)
    cost = tonumber(cost)
    return ok and cost ~= nil and GetCoins() >= cost
end

local function SmartPurchaseRebirth()
