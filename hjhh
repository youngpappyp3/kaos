local function SafeNotify(data)
    if Rayfield and type(Rayfield.Notify) == "function" then
        local ok, err = pcall(function()
            Rayfield:Notify(data)
        end)
        if not ok then
            HubWarn("Notify", err)
        end
    end
end

local function StartManagedLoop(name, isRunning, tickFn, errDelay)
    if ActiveLoops[name] then return end
    ActiveLoops[name] = true
    task.spawn(function()
        while isRunning() do
            local ok, waitTime = xpcall(tickFn, function(err)
                return tostring(err) .. "\n" .. debug.traceback()
            end)
            if ok then
                task.wait(math.max(type(waitTime) == "number" and waitTime or MIN_LOOP_WAIT, MIN_LOOP_WAIT))
            else
                HubWarn("Loop " .. tostring(name), waitTime)
                task.wait(math.max(tonumber(errDelay) or 1, MIN_LOOP_WAIT))
            end
        end
        ActiveLoops[name] = nil
    end)
end

local function SetRayfieldLabel(label, text)
    if not label then
        return
