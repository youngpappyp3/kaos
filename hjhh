    if InventorySnapshotCache and now - InventorySnapshotCacheTime <= INVENTORY_CACHE_SECONDS then
        inv = InventorySnapshotCache
    else
        local ok, snapshot = SafeInvoke(GetInventorySnapshot)
        if ok and typeof(snapshot) == "table" then
            inv = snapshot
