local DigSection = DigTab:CreateSection("Digging")
local DigLabel = DigTab:CreateLabel("Smart Auto Dig")
local AutoDig = false
local DigSquareIndex = 1
local DigGridColumns = 6
local DigGridRows = 3
local DigInterval = 1.1
local DigRegenDelay = 1.5
local DigStaminaCost = 5
local DigBoardSize = DigGridColumns * DigGridRows
local AutoDigToggle = DigTab:CreateToggle({
   Name = "Auto Dig",
   CurrentValue = false,
   Flag = "AutoDigToggle",
   Callback = function(Value)
      AutoDig = Value

      if AutoDig then
         StartManagedLoop("AutoDig", function()
            return AutoDig
         end, function()
            local currentStamina, maxStamina = GetStaminaValues()

            if currentStamina and maxStamina and currentStamina <= 0 then
               return DigRegenDelay
            elseif currentStamina and currentStamina < DigStaminaCost then
               return DigRegenDelay
            end

            DigSquare:FireServer(DigSquareIndex)
            DigSquareIndex = DigSquareIndex + 1

            if DigSquareIndex > DigBoardSize then
               DigSquareIndex = 1
               return math.max(DigInterval, 1.2)
            end

            return DigInterval
         end, 1)
      else
         DigSquareIndex = 1
      end
   end,
})

