local AutoMinigameResult = false
local LastHandledOverlay = nil
local AutoMinigameResultToggle = FishTab:CreateToggle({
   Name = "Auto Complete Minigame",
   CurrentValue = false,
   Flag = "AutoMinigameResultToggle",
   Callback = function(Value)
      AutoMinigameResult = Value
      Log("AutoMinigame", "Toggled " .. (Value and "ON" or "OFF"))

      if not AutoMinigameResult then
         LastHandledOverlay = nil
         return
      end

      StartManagedLoop("AutoMinigameResult", function()
         return AutoMinigameResult
      end, function()
         local overlay = FindMinigameOverlay()
         if overlay then
            if overlay ~= LastHandledOverlay then
               -- New popup detected – fire instantly
               Log("AutoMinigame", "MinigameOverlay detected! Firing MinigameResult(true, false) multiple times")
               
               -- Fire 2 to 3 times with slightly random timing to ensure it registers
               task.spawn(function()
                  local fires = math.random(2, 3)
                  for i = 1, fires do
                     MinigameResult:FireServer(true, false)
                     if i < fires then
                        task.wait(math.random(3, 8) / 100) -- Wait between 0.03s - 0.08s
                     end
                  end
               end)
               
               LastHandledOverlay = overlay
               Log("AutoMinigame", "Fired OK – waiting for overlay to disappear")
            end
         else
            if LastHandledOverlay ~= nil then
               -- overlay just disappeared
               Log("AutoMinigame", "Overlay gone – ready for next popup")
            end
            LastHandledOverlay = nil
         end

         return 0.01  -- poll every 10ms for near-instant detection
      end, 0.5)
   end,
})

