        dataSync.OnClientEvent:Connect(function(syncType, payload)
            if typeof(payload) ~= "table" then
                return
            end
            if syncType == "Full" then
                MergeTable(DataCache, payload)
            elseif syncType == "InventoryDelta" and typeof(payload.full) == "table" then
                DataCache.Inventory = payload.full
            elseif syncType == "CurrencyDelta" and typeof(payload.Currencies) == "table" then
                DataCache.Currencies = payload.Currencies
            elseif syncType == "UpgradeDelta" and typeof(payload.Upgrades) == "table" then
                DataCache.Upgrades = payload.Upgrades
