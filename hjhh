local function GetRankedBrawlerScore(brawlerId, state, inventory, mode)
    local level = math.max(1, math.floor(tonumber(state and state.level) or 1))
    local trophies = math.max(0, math.floor(tonumber(state and state.trophies) or 0))
    local brawler = BrawlerLibrary and BrawlerLibrary.ById and BrawlerLibrary.ById[brawlerId] or nil
    local rarityScore = BrawlerRarityScore[brawler and brawler.rarity or ""] or 0
    local selectedBonus = inventory and inventory.selectedBrawlerId == brawlerId and 1000000000 or 0
    local orderPenalty = tonumber(brawler and brawler.order) or 9999

    if mode == "Selected Brawler" then
        return selectedBonus + level * 1000000 + trophies * 100 + rarityScore * 1000 - orderPenalty
    end

    if mode == "Highest Level" then
        return level * 100000000 + trophies * 100 + rarityScore * 1000 - orderPenalty
    end

    if mode == "Highest Trophies" then
        return trophies * 100000 + level * 1000 + rarityScore * 100 - orderPenalty
    end

    return level * 10000000 + trophies * 1000 + rarityScore * 100000 - orderPenalty
end

local function GetBestRankedBrawlerCandidates(inventory)
    local candidates = {}
    if typeof(inventory) == "table" and typeof(inventory.byId) == "table" then
        for brawlerId, state in pairs(inventory.byId) do
            if typeof(brawlerId) == "string" and typeof(state) == "table" and state.unlocked == true then
                candidates[#candidates + 1] = {
                    id = brawlerId,
                    score = GetRankedBrawlerScore(brawlerId, state, inventory, RankedBrawlerMode),
                }
            end
        end
    end

    if #candidates <= 0 then
        return { { id = "shelly", score = 0 } }
    end

    table.sort(candidates, function(a, b)
        return a.score > b.score
    end)
    return candidates
end

local function GetRankedRotationLimit(candidateCount)
    if RankedBrawlerMode == "Rotate Top 3" then
        return math.min(candidateCount, 3)
    end
    if RankedBrawlerMode == "Rotate Top 5" then
        return math.min(candidateCount, 5)
    end
    return 0
end

local function GetRankedRoundAttemptOrder(candidates, roundNumber)
    if typeof(candidates) ~= "table" or #candidates <= 0 then
        return { { id = "shelly", score = 0 } }
    end

    local limit = GetRankedRotationLimit(#candidates)
    if limit <= 1 then
        return candidates
    end

    local ordered = {}
    local added = {}
    local startIndex = ((math.max(1, math.floor(tonumber(roundNumber) or 1)) - 1) % limit) + 1

    for offset = 0, limit - 1 do
        local index = ((startIndex + offset - 1) % limit) + 1
        local candidate = candidates[index]
        if candidate and not added[candidate.id] then
            added[candidate.id] = true
            ordered[#ordered + 1] = candidate
        end
    end

    for _, candidate in ipairs(candidates) do
        if candidate and not added[candidate.id] then
            added[candidate.id] = true
            ordered[#ordered + 1] = candidate
        end
    end

    return ordered
end

local function GetRankedRoundLeadBrawlerId(candidates, roundNumber)
    local order = GetRankedRoundAttemptOrder(candidates, roundNumber)
    local first = order and order[1]
    return typeof(first) == "table" and first.id or "shelly"
end

local function SelectBestRankedBrawler(candidates)
    local best = candidates and candidates[1]
    local bestId = typeof(best) == "table" and best.id or "shelly"
    if typeof(bestId) ~= "string" or bestId == "" then
        bestId = "shelly"
    end

    if SafeFire(SelectBrawler, bestId) then
        InvalidateInventorySnapshot()
        task.wait(0.08)
    end
    return bestId
end

local function ExtractRankedRewardToken(result)
    if typeof(result) ~= "table" then
        return nil
    end
    local token = result.rankedRewardRollToken or result.rewardRollToken or result.rollToken
    if token then
        return token
    end
    if typeof(result.matchResult) == "table" then
        return ExtractRankedRewardToken(result.matchResult)
    end
    return nil
end

local function ResolveRankedRound(matchId, roundNumber, candidates)
    local lastMessage = nil
    for _, candidate in ipairs(GetRankedRoundAttemptOrder(candidates, roundNumber)) do
        local brawlerId = candidate.id
        if SafeFire(SelectBrawler, brawlerId) then
            task.wait(0.08)
        end
        local roundOk, round = SafeInvoke(RankedRoundResolve, matchId, roundNumber, brawlerId)
        local retries = 0
        while roundOk and typeof(round) == "table" and round.ok ~= true and (round.code == "too_fast" or round.code == "rate_limited") and retries < 4 do
            task.wait(math.clamp(tonumber(round.retryAfter) or 0.75, 0.5, 6))
            roundOk, round = SafeInvoke(RankedRoundResolve, matchId, roundNumber, brawlerId)
            retries += 1
        end

        if roundOk and typeof(round) == "table" and round.ok == true then
            return true, round, brawlerId
        end

        lastMessage = typeof(round) == "table" and round.message or "round failed"
        task.wait(0.15)
    end

    return false, lastMessage, nil
end

local function GetRankedRoundPaceDelay(round)
    local baseDelay = math.max(tonumber(RuntimeSettings.RankedRoundDelay) or 4.5, 0.75)
    if typeof(round) == "table" then
        local retryAfter = tonumber(round.retryAfter)
        if retryAfter and retryAfter > 0 then
            return math.max(baseDelay, math.clamp(retryAfter, 0.75, 8))
        end
    end
    return baseDelay
end

local function FinishRankedMatch(matchId)
    if typeof(matchId) ~= "string" or matchId == "" or not RankedMatchFinish then
        return false, nil
    end
    return SafeInvoke(RankedMatchFinish, matchId)
end

local function GetRankedMatchResult(round)
    if typeof(round) ~= "table" then
        return nil
    end
    if typeof(round.matchResult) == "table" and round.matchResult.ok == true then
        return round.matchResult
    end
    if round.matchFinished == true then
        return round
    end
    return nil
end

local function GetRankedResultText(result, playerWins, opponentWins)
    if typeof(result) ~= "table" then
        return string.format("%d-%d", tonumber(playerWins) or 0, tonumber(opponentWins) or 0)
    end

    local didWin = result.playerWon
    if didWin == nil then
        didWin = result.didWin
    end

    local outcome = didWin == true and "Won" or "Lost"
    local after = tonumber(result.afterRankedTrophies or result.rankedTrophies)
    if after then
        return string.format("%s | %d-%d | Trophies: %d", outcome, tonumber(playerWins) or 0, tonumber(opponentWins) or 0, after)
    end
    return string.format("%s | %d-%d", outcome, tonumber(playerWins) or 0, tonumber(opponentWins) or 0)
end

local function RollRankedReward(token)
    if typeof(token) ~= "string" or token == "" or not RankedRewardRoll then
        return false, nil
    end
    return SafeInvoke(RankedRewardRoll, token)
end

local function AutoPlayRankedMatch(autoRollReward)
    if not RankedMatchStart or not RankedRoundResolve then
        SetRankedStatus("Ranked remotes missing")
        return false
    end

    local _, inventory = GetBattleSlots()
    local rankedCandidates = GetBestRankedBrawlerCandidates(inventory)
    local selectedBrawlerId = SelectBestRankedBrawler(rankedCandidates)
    SetRankedStatus("Starting ranked: " .. tostring(selectedBrawlerId))

    local startOk, startResult = SafeInvoke(RankedMatchStart)
    if not startOk or typeof(startResult) ~= "table" or startResult.ok ~= true then
        local message = typeof(startResult) == "table" and startResult.message or "start failed"
        SetRankedStatus("Ranked start failed: " .. tostring(message))
        return false
    end

    local matchId = startResult.matchId
    if typeof(matchId) ~= "string" or matchId == "" then
        SetRankedStatus("Ranked start failed: no match id")
        return false
    end

    player:SetAttribute("RankedMatchActive", true)

    local playerWins = 0
    local opponentWins = 0
    local matchResult = nil
    local lastBrawlerId = selectedBrawlerId

    for roundNumber = 1, 9 do
        local plannedBrawlerId = GetRankedRoundLeadBrawlerId(rankedCandidates, roundNumber)
        SetRankedStatus(string.format("Resolving round %d with %s", roundNumber, tostring(plannedBrawlerId)))
        local roundOk, round, usedBrawlerId = ResolveRankedRound(matchId, roundNumber, rankedCandidates)
        lastBrawlerId = usedBrawlerId or lastBrawlerId

        if not roundOk then
            FinishRankedMatch(matchId)
            player:SetAttribute("RankedMatchActive", false)
            SetRankedStatus("Round failed: " .. tostring(round))
            return false
        end

        playerWins = math.max(0, math.floor(tonumber(round.playerWins) or playerWins))
        opponentWins = math.max(0, math.floor(tonumber(round.opponentWins) or opponentWins))
        SetRankedStatus(string.format("Round %d done: %d-%d | %s", roundNumber, playerWins, opponentWins, tostring(lastBrawlerId)))

        matchResult = GetRankedMatchResult(round)
        if matchResult then
            break
        end

        local paceDelay = GetRankedRoundPaceDelay(round)
        SetRankedStatus(string.format("Waiting %.1fs before round %d", paceDelay, roundNumber + 1))
        task.wait(paceDelay)
    end

    if not matchResult then
        local finishOk, finishResult = FinishRankedMatch(matchId)
        if finishOk and typeof(finishResult) == "table" and finishResult.ok == true then
            matchResult = finishResult
            playerWins = math.max(0, math.floor(tonumber(finishResult.playerWins) or playerWins))
            opponentWins = math.max(0, math.floor(tonumber(finishResult.opponentWins) or opponentWins))
        end
    end

    player:SetAttribute("RankedMatchActive", false)

    local resultText = GetRankedResultText(matchResult, playerWins, opponentWins)
    SetRankedResult(resultText)

    local token = ExtractRankedRewardToken(matchResult)
    if autoRollReward and token then
        SetRankedStatus("Rolling ranked reward")
        local rewardOk, reward = RollRankedReward(token)
        if rewardOk and typeof(reward) == "table" and reward.ok == true then
            SetRankedStatus("Ranked complete + reward rolled")
        else
            local message = typeof(reward) == "table" and reward.message or "reward failed"
            SetRankedStatus("Ranked complete | reward failed: " .. tostring(message))
        end
    else
        SetRankedStatus("Ranked complete")
    end

    return true
end

