local function GetInventoryItemCount(itemId)
    local count = 0
    if typeof(DataCache.Inventory) ~= "table" then
        return 0
    end
    for _, entry in pairs(DataCache.Inventory) do
        if typeof(entry) == "table" and entry.id == itemId then
            count += math.max(1, math.floor(tonumber(entry.quantity or entry.count) or 1))
        end
    end
    return count
end

local function GetInventoryEntriesByType(itemType)
    local entries = {}
    if typeof(DataCache.Inventory) ~= "table" or not ItemConfig then
        return entries
    end
    for _, entry in pairs(DataCache.Inventory) do
        if typeof(entry) == "table" and typeof(entry.id) == "string" then
            local item = ItemConfig.GetItem and ItemConfig.GetItem(entry.id)
            if item and item.type == itemType then
                entries[#entries + 1] = {
                    id = entry.id,
                    quantity = math.max(1, math.floor(tonumber(entry.quantity or entry.count) or 1)),
                    untradable = entry.untradable,
                }
            end
        end
    end
    return entries
end

local function GetPetLevel(pet)
    if not PetConfig or not PetConfig.GetLevelFromXP then
        return 0
    end
    return tonumber(PetConfig.GetLevelFromXP(tonumber(pet and pet.xp) or 0)) or 0
end

local function GetPetRarityScore(petId)
    if not PetConfig then
        return 0
    end
    local pet = PetConfig.GetPet and PetConfig.GetPet(petId) or (PetConfig.Pets and PetConfig.Pets[petId])
    local rarity = pet and pet.rarity or "Common"
    local order = PetConfig.RarityOrder or {}
    for i, name in ipairs(order) do
        if name == rarity then
            return i
        end
    end
    return 0
end

local function GetBestOwnedPet()
    local best
    if typeof(PetDataCache.Owned) ~= "table" then
        return nil
    end
    for _, pet in pairs(PetDataCache.Owned) do
        if typeof(pet) == "table" and typeof(pet.uniqueId) == "string" then
            local score = GetPetLevel(pet) * 1000 + GetPetRarityScore(pet.petId) * 100
            if not best or score > best.score then
                best = { pet = pet, score = score }
            end
        end
    end
    return best and best.pet or nil
end

local function HasAliveTarget(instance)
    if not instance or not instance.Parent then
        return false
    end
    local alive = instance:GetAttribute("Alive")
    if alive == false then
        return false
    end
    local hp = instance:GetAttribute("HP") or instance:GetAttribute("Health")
    if type(hp) == "number" and hp <= 0 then
        return false
    end
    return true
end

local function GetTargetPosition(instance)
    if not instance then
        return nil
    end
    if instance:IsA("Model") then
        local part = instance.PrimaryPart or instance:FindFirstChildWhichIsA("BasePart", true)
        return part and part.Position or nil
    end
    if instance:IsA("BasePart") then
        return instance.Position
    end
    local part = instance:FindFirstChildWhichIsA("BasePart", true)
    return part and part.Position or nil
end

local function GetRoot()
    local character = player.Character
    return character and character:FindFirstChild("HumanoidRootPart") or nil
end

local function GetDistanceToTarget(target)
    local root = GetRoot()
    local pos = GetTargetPosition(target)
    if root and pos then
        return (root.Position - pos).Magnitude
    end
    return math.huge
end

local function AddTarget(list, target, source, priority)
    if not HasAliveTarget(target) then
        return
    end
    local pos = GetTargetPosition(target)
    if not pos then
        return
    end
    list[#list + 1] = {
        target = target,
        source = source,
        distance = GetDistanceToTarget(target),
        priority = priority or 0,
    }
end

local function CollectMobTargets()
    local targets = {}
    for _, mob in ipairs(CollectionService:GetTagged("Mob")) do
        AddTarget(targets, mob, "Mob", mob:GetAttribute("IsBoss") and 1000 or 0)
    end
    local folder = Workspace:FindFirstChild("Mobs")
    if folder then
        for _, mob in ipairs(folder:GetChildren()) do
            AddTarget(targets, mob, "Mob", mob:GetAttribute("IsBoss") and 1000 or 0)
        end
    end
    return targets
end

local function CollectResourceTargets()
    local targets = {}
    local seen = {}
    if ResourceConfig and typeof(ResourceConfig.AllResources) == "table" then
        for resourceId, cfg in pairs(ResourceConfig.AllResources) do
            for _, node in ipairs(CollectionService:GetTagged(resourceId)) do
                if not seen[node] then
                    seen[node] = true
                    AddTarget(targets, node, "Resource", cfg.isRare and 750 or 0)
                end
            end
        end
    end
    for _, folderName in ipairs({ "Resources", "ResourceNodes", "MapResources" }) do
        local folder = Workspace:FindFirstChild(folderName)
        if folder then
            for _, node in ipairs(folder:GetDescendants()) do
                if (node:IsA("Model") or node:IsA("BasePart")) and not seen[node] then
                    seen[node] = true
                    AddTarget(targets, node, "Resource", 0)
                end
            end
        end
    end
    return targets
end

local function ChooseTarget(mode)
    local targets = {}
    if mode == "Nearest Mob" then
        targets = CollectMobTargets()
    elseif mode == "Nearest Resource" then
        targets = CollectResourceTargets()
    elseif mode == "Boss/Rare First" then
        for _, t in ipairs(CollectMobTargets()) do targets[#targets + 1] = t end
        for _, t in ipairs(CollectResourceTargets()) do targets[#targets + 1] = t end
    else
        for _, t in ipairs(CollectMobTargets()) do targets[#targets + 1] = t end
        for _, t in ipairs(CollectResourceTargets()) do targets[#targets + 1] = t end
    end

    table.sort(targets, function(a, b)
        if a.priority == b.priority then
            return a.distance < b.distance
        end
        return a.priority > b.priority
    end)
    return targets[1]
end

