local function GetBrawlerUpgradeCost(brawlerId, state)
    if not BrawlerProgressionConfig or not BrawlerProgressionConfig.getUpgradeCostsForLevel then
        return nil
    end

    local brawler = BrawlerLibrary and BrawlerLibrary.ById and BrawlerLibrary.ById[brawlerId] or nil
